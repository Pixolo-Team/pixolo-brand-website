---
// COMPONENTS //
import ServiceItem from "@/components/ui/ServiceItem.astro";
import ToolBadge from "@/components/ui/ToolBadge.astro";
import RoundedButton from "@/components/ui/RoundedButton.astro";

// CONSTANTS //
import { URLS } from "@/infrastructure/constants/urls";

// DATA //
import { serviceDetails, serviceSectionDetails } from "@/data/home/services.ts";
---

<!-- Service Section -->
<section id="services-section" data-section="Services">
  <!-- Container -->
  <div
    class="container mx-auto flex w-full flex-col flex-wrap items-start justify-center gap-12 px-6 py-16 md:gap-16 md:px-4 md:py-24 lg:gap-20 lg:px-0 lg:px-8 lg:py-26"
  >
    <!-- Section Header -->
    <div class="relative flex flex-col flex-wrap gap-6 lg:gap-7">
      <!-- Tool Badge -->
      <div class="flex items-center justify-start self-start">
        <ToolBadge icon="service-icon" text={serviceSectionDetails.badgeTitle} />
      </div>

      <!-- Text -->
      <p class="anim-fade-in-right text-n-950 w-fit text-2xl leading-tight font-normal md:text-5xl">
        {serviceSectionDetails.title}
      </p>
    </div>

    <!-- Content Wrap -->
    <div
      class="mx-auto grid w-full grid-cols-1 gap-11 md:gap-16 lg:grid-cols-2 lg:gap-x-12 lg:gap-y-20 2xl:grid-cols-3"
    >
      {
        serviceDetails.map((serviceItem) => (
          <a
            href={URLS.SERVICE.ITEM(serviceItem.slug)}
            data-service-item={serviceItem.title}
            class="service-card"
          >
            <ServiceItem
              imageName={serviceItem.imageName}
              title={serviceItem.title}
              tags={serviceItem.tags}
            />
          </a>
        ))
      }
    </div>

    <div class="flex w-full justify-center">
      <a href={URLS.SERVICE.ROOT}>
        <RoundedButton variant="tertiary" buttonText="View all Services" />
      </a>
    </div>
  </div>
</section>
<script>
  import { trackServiceInterest } from "@/scripts/analytics";

  // Single event listener for ALL cards (event delegation)
  document.addEventListener("click", (e) => {
    const card = (e.target as HTMLElement).closest(".service-card");
    if (card) {
      const serviceName = card.getAttribute("data-service-item");
      if (serviceName) {
        trackServiceInterest(serviceName);
      }
    }
  });
</script>
