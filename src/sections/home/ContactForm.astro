---
// COMPONENTS //
import Image from "astro/components/Image.astro";
import ToolBadge from "@/components/ToolBadge.astro";
import { Icon } from "astro-icon/components";
import Tooltip from "@/components/Tooltip.astro";
import ContactCard from "@/components/ContactCard.astro";
import InputField from "@/components/InputField.astro";
import Dropdown from "@/components/Dropdown.astro";
import Textarea from "@/components/Textarea.astro";
import RoundedButton from "@/components/RoundedButton.astro";

// OTHERS //
import { initializeFormValidation, initializeCopyButtons } from "@/scripts/contact-form";

// SVG's //
import Ball from "@/assets/3d-ball.svg";

// DATA //
import { contactSectionDetails, contactFormDetails } from "@/data/contact";

// HELPERS //
// Helper: phone value for WhatsApp link
const phoneContact = contactSectionDetails.contactCards.find((c) => c.id === "phone")?.value || "";
---

<section id="contact-section" class="relative flex flex-col py-12 md:py-20 lg:px-0 lg:py-32">
  <div id="contact-wrapper" class="container mx-auto max-w-[327px] px-6 md:px-0 lg:max-w-[1536px]">
    {/* Header - "Want to know more?" + "We'd love to hear from you" */}
    <div class="text-n-950 flex w-full flex-col items-center gap-5 lg:gap-6">
      {/* top tool badge */}
      <ToolBadge
        icon="building"
        text={contactFormDetails.badgeTitle}
        class:list={"text-n-950 md:text-base"}
      />
      {/* subtitle text */}
      <p
        class="font-neometric text-n-950 text-center text-3xl leading-[125%] font-medium md:text-4xl lg:text-6xl"
      >
        {contactFormDetails.heading}
      </p>
    </div>

    {/* Contact cards (stacked) - after header */}
    <div
      class="mt-8 flex w-full flex-col gap-4 md:mt-10 md:gap-6 lg:mx-auto lg:flex-row lg:items-center lg:justify-center lg:gap-6"
    >
      {
        contactSectionDetails.contactCards.map((card) => (
          <div class="w-full lg:max-w-sm">
            <ContactCard
              icon={card.icon}
              title={card.title}
              value={card.value}
              type={card.id}
              link={card.link}
            />
          </div>
        ))
      }

      {/* Location card */}
      <div class="w-full lg:max-w-sm">
        <ContactCard
          icon={contactSectionDetails.location.icon}
          title={contactSectionDetails.location.title}
          value={contactSectionDetails.location.address}
          type="location"
          link={contactSectionDetails.location.mapUrl}
        />
      </div>
    </div>

    {/* Fill area: heading (fixed width 724px) + form (fills) - laptop layout */}
    <div class="contact-fill-wrap mt-10 lg:flex lg:flex-row lg:gap-48 lg:pt-9 lg:pb-9">
      {/* Decorative balls positioned relative to section - Fixed width wrapper */}
      <div class="fixedwidth-text-wrap relative w-full lg:w-[724px]">
        <p
          class="font-neometric text-n-950 text-8xl leading-tight font-normal tracking-tight md:leading-none md:tracking-tight"
        >
          Lets
        </p>
        <Image
          id="contact-big-marble"
          src={Ball}
          alt="big marble"
          class="pointer-events-none absolute top-8 left-12 -z-10 w-[59.13px] md:top-12 md:left-20 lg:top-[35%] lg:left-[15%]"
        />
        <Image
          id="contact-small-marble"
          src={Ball}
          alt="small marble"
          class="pointer-events-none absolute top-16 -right-3 -z-10 w-[38.01px] rotate-[-20deg] md:top-20 md:-right-6 lg:top-[55%] lg:right-[8%]"
        />
        <p
          class="font-neometric text-n-950 text-8xl leading-tight font-normal tracking-tight md:text-right md:leading-tight md:tracking-tight"
        >
          get in
        </p>
        <p
          class="font-neometric text-n-950 text-8xl leading-tight font-normal tracking-tight md:leading-relaxed md:tracking-tight"
        >
          Touch!
        </p>
      </div>

      {/* Form using InputField components */}
      <div class="form-fill w-full lg:flex-1">
        <form class="mt-20 flex flex-col gap-5 md:gap-11 lg:gap-12" aria-label="Contact form">
          <!-- NAME -->
          <div class="md:gap-8 md:pb-9">
            <InputField
              label="NAME"
              name="name"
              id="name"
              type="text"
              required={true}
              placeholder="NAME"
            />
          </div>

          <!-- PHONE NUMBER -->
          <div class="md:gap-8 md:pb-9">
            <InputField
              label="PHONE NUMBER"
              name="phone"
              id="phone"
              type="tel"
              required={true}
              placeholder="PHONE NUMBER"
            />
          </div>

          <!-- E-MAIL -->
          <div class="md:gap-8 md:pb-9">
            <InputField
              label="E-MAIL"
              name="email"
              id="email"
              type="email"
              required={true}
              placeholder="E-MAIL"
            />
          </div>

          <!-- MESSAGE -->
          <div class="md:gap-8 md:pb-9">
            <InputField
              label="MESSAGE"
              name="message"
              id="message"
              type="text"
              required={true}
              placeholder="MESSAGE"
            />
          </div>

          <!-- Submit button-->
          <div class="relative mt-6 flex items-end justify-start">
            <div class="scale-95 transform">
              <RoundedButton
                buttonText={"Contact Us"}
                type="button"
                onClick="window.dispatchEvent(new Event('open-contact-modal'))"
                variant="secondary"
                class:list={"bg-n-950 text-n-50"}
              />
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  import { initializeCopyButtons, initializeFormValidation } from "@/scripts/contact-form";

  document.addEventListener("DOMContentLoaded", () => {
    initializeFormValidation();
    initializeCopyButtons();
  });
</script>
