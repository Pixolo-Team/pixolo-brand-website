---
/* assets & components */
import Ball from "@/assets/3d-ball.svg";
import Image from "astro/components/Image.astro";

import ToolBadge from "@/components/ToolBadge.astro";
import { Icon } from "astro-icon/components";
import Tooltip from "@/components/Tooltip.astro";

import InputField from "@/components/InputField.astro";
import Dropdown from "@/components/Dropdown.astro";
import Textarea from "@/components/Textarea.astro";
import RoundedButton from "@/components/RoundedButton.astro";
import WhatsappButton from "@/components/WhatsappButton.astro";
import ContactFormModal from "@/components/forms/ContactForm.astro";
/* data */
import { contactSectionDetails, contactFormDetails } from "@/data/contact";

// helper: phone value for WhatsApp link
const phoneContact = contactSectionDetails.contactCards.find((c) => c.id === "phone")?.value || "";
---

<section id="contact-section" class="relative flex flex-col py-12 md:py-20 lg:px-0 lg:py-32">
  <div id="contact-wrapper" class="container mx-auto max-w-[327px] px-6 md:px-0 lg:max-w-[1536px]">
    {/* Header - "Want to know more?" + "We'd love to hear from you" */}
    <div class="text-n-950 flex w-full flex-col items-center gap-4 md:gap-5 lg:gap-6">
      {/* top tool badge */}
      <ToolBadge
        icon="building"
        text={contactFormDetails.badgeTitle}
        class:list={"text-n-950 md:text-base"}
      />
      {/* subtitle text */}
      <p
        class="font-neometric text-n-950 text-center text-3xl leading-[125%] font-medium md:text-4xl lg:text-6xl"
      >
        {contactFormDetails.heading}
      </p>
    </div>

    {/* Contact cards (stacked) - after header */}
    <div
      class="mt-8 flex w-full flex-col gap-4 md:mt-10 md:gap-16 lg:mx-auto lg:flex-row lg:items-center lg:justify-center lg:gap-9"
    >
      {
        contactSectionDetails.contactCards.map((card) => {
          const tooltipText =
            card.id === "phone" ? "Call" : card.id === "mail" ? "Email" : "Location";
          return (
            <a
              href={card.link}
              class="bg-n-950/5 hover:bg-n-950/6 flex items-center justify-between gap-4 rounded-[28px] px-5 py-4"
            >
              <div class="flex max-w-[80%] items-center gap-4">
                {/* circular icon */}
                <div class="flex h-[54px] w-[54px] items-center justify-center rounded-full bg-linear-to-r from-[#6C6AF2] to-[#8B77F3] shadow-sm">
                  <Icon name={card.icon} class="text-n-950 size-6" />
                </div>

                {/* title + value */}
                <div class="flex w-[60%] flex-col">
                  <p class="font-neometric text-n-700 text-xs font-extrabold md:text-sm">
                    {card.title}
                  </p>
                  <p class="text-n-950 max-w-[180px] truncate text-sm font-semibold md:text-lg">
                    {card.value}
                  </p>
                </div>
              </div>

              {/* Right-side control: copy button for phone/mail, arrow for others */}
              {card.id === "phone" || card.id === "mail" ? (
                <Tooltip text="Copy" position="top">
                  <span
                    class="bg-n-950/2 hover:bg-n-950/4 text-n-300 flex h-8 w-8 items-center justify-center rounded-full p-1"
                    data-copy={card.value}
                  >
                    <Icon name="copy" class="icon-copy text-n-300 size-[26px]" />
                    <Icon name="check" class="icon-check hidden size-[26px]" />
                  </span>
                </Tooltip>
              ) : (
                <Icon name="right-arrow" class="text-n-300 size-5" />
              )}
            </a>
          );
        })
      }

      {/* Location card */}
      <a
        href={contactSectionDetails.location.mapUrl}
        class="bg-n-950/5 hover:bg-n-950/6 flex items-center justify-between gap-4 rounded-[28px] px-5 py-4"
      >
        <div class="flex max-w-[80%] items-center gap-4">
          {/* circular icon */}
          <div
            class="flex h-[54px] w-[54px] items-center justify-center rounded-full bg-linear-to-r from-[#6C6AF2] to-[#8B77F3] shadow-sm"
          >
            <Icon name={contactSectionDetails.location.icon} class="text-n-950 size-[26px]" />
          </div>

          {/* title + value */}
          <div class="flex w-[60%] flex-col">
            <p class="font-neometric text-n-700 text-xs font-extrabold md:text-sm">
              {contactSectionDetails.location.title}
            </p>
            <p class="text-n-950 max-w-[180px] truncate text-sm font-semibold md:text-lg">
              {contactSectionDetails.location.address}
            </p>
          </div>
        </div>

        {/* right arrow for location */}
        <Icon name="right-arrow" class="text-n-300 size-5" />
      </a>
    </div>

    {/* Fill area: heading (fixed width) + form (fills) - laptop layout */}
    <div class="contact-fill-wrap mt-10 text-wrap lg:flex lg:flex-row lg:gap-48 lg:pt-9 lg:pb-9">
      {/* Decorative balls positioned relative to section */}
      <div class="fixedwidth-text-wrap w-full lg:w-[724px]">
        <p
          class="font-neometric text-n-950 text-8xl leading-tight font-normal tracking-tight md:leading-none md:tracking-tight"
        >
          Lets
        </p>
        <Image
          id="contact-big-marble"
          src={Ball}
          alt="big marble"
          class="pointer-events-none absolute top-[35%] left-[15%] w-[59.13px]"
        />
        <Image
          id="contact-small-marble"
          src={Ball}
          alt="small marble"
          class="pointer-events-none absolute top-[55%] right-[8%] w-[38.01px] rotate-[-20deg]"
        />
        <p
          class="font-neometric text-n-950 text-8xl leading-tight font-normal tracking-tight md:text-right md:leading-tight md:tracking-tight"
        >
          get in
        </p>
        <p
          class="font-neometric text-n-950 text-8xl leading-tight font-normal tracking-tight md:leading-relaxed md:tracking-tight"
        >
          Touch!
        </p>
      </div>

      {/* Form using InputField components */}
      <div class="form-fill w-full lg:flex-1">
        <form class="mt-20 flex flex-col gap-5 md:gap-11 lg:gap-12" aria-label="Contact form">
          <!-- NAME -->
          <div class="md:gap-8 md:pb-9">
            <InputField
              label="NAME"
              name="name"
              id="name"
              type="text"
              required={true}
              placeholder="NAME"
            />
          </div>

          <!-- PHONE NUMBER -->
          <div class="md:gap-8 md:pb-9">
            <InputField
              label="PHONE NUMBER"
              name="phone"
              id="phone"
              type="tel"
              required={true}
              placeholder="PHONE NUMBER"
            />
          </div>

          <!-- E-MAIL -->
          <div class="md:gap-8 md:pb-9">
            <InputField
              label="E-MAIL"
              name="email"
              id="email"
              type="email"
              required={true}
              placeholder="E-MAIL"
            />
          </div>

          <!-- MESSAGE -->
          <div class="md:gap-8 md:pb-9">
            <InputField
              label="MESSAGE"
              name="message"
              id="message"
              type="text"
              required={true}
              placeholder="MESSAGE"
            />
          </div>

          <!-- Submit button-->
          <div class="relative mt-6 flex items-end justify-start">
            <div class="scale-95 transform">
              <RoundedButton
                buttonText={"Contact Us"}
                type="button"
                onClick="window.dispatchEvent(new Event('open-contact-modal'))"
                variant="secondary"
                class:list={"bg-n-950 text-n-50"}
              />
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
