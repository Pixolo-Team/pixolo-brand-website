---
// COMPONENTS //
import BlogCard from "@/components/blogs/BlogCard.astro";
import ToolBadge from "@/components/ToolBadge.astro";
import RoundedButton from "src/components/RoundedButton.astro";

// DATA //
import { blogSectionDetails } from "@/data/blogs";
import { blogItems } from "@/data/blogs";
---

<!-- Blogs Section -->
<section>
  <div class="container mx-auto flex flex-col gap-16 px-6 py-20 md:gap-20 md:py-28 lg:gap-24">
    <div class="flex flex-col items-start gap-4 md:gap-5 lg:gap-6">
      <!-- Tool Badge -->
      <ToolBadge icon={"comment"} text={blogSectionDetails.badgeTitle} />

      <!-- Heading -->
      <p
        class="text-n-950 text-2xl leading-tight font-normal tracking-tighter md:text-4xl lg:text-6xl"
      >
        {blogSectionDetails.heading}
      </p>
    </div>

    <!-- Blog Cards and Add More Button -->
    <div class="flex flex-col items-center gap-16">
      <!-- Blog Cards Wrapper -->
      <div class="grid w-full grid-cols-1 gap-12 md:grid-cols-2 md:gap-7 lg:grid-cols-3 lg:gap-12">
        <!-- Blog Cards -->
        {
          blogItems.map((card) => (
            <BlogCard
              imageSrc={card.imageSrc}
              category={card.category}
              date={card.date}
              title={card.title}
              author={card.author}
              href={card.href}
            />
          ))
        }
      </div>

      <!-- Load More Button -->
      <RoundedButton
        buttonText={blogSectionDetails.loadMoreButton}
        onClick="window.location.href='/404'"
        type="button"
        variant="tertiary"
      />
      <!-- <button
        type="button"
        aria-label="Load more blog posts"
        onclick="window.location.href='/404'"
        class="border-n-500 text-n-950 flex cursor-pointer gap-1.5 rounded-4xl border px-6 py-3.5 text-sm md:px-8 lg:gap-2 lg:px-7 lg:py-4 lg:text-base"
        >{blogSectionDetails.loadMoreButton}</button
      > -->
    </div>
  </div>
</section>
