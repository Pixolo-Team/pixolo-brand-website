---
//COMPONENT//
import CaseStudyCard from "@/components/casestudy/CaseStudyCard.astro";
import ToolBadge from "@/components/ToolBadge.astro";

//DATA//
import { caseStudies } from "@/data/case-studies";
---

<section>
  <container class="flex flex-col gap-12 px-6 py-16">
    {/* Header Section */}
    <div class="flex flex-col gap-2.5">
      <div class="flex justify-center">
        <ToolBadge icon="puzzle-icon" text="Case Studies" />
      </div>
      <p
        class="flex justify-center text-center text-2xl leading-tight font-medium tracking-normal md:text-4xl lg:text-6xl"
      >
        Smart Solutions to Real Challenges.
      </p>
    </div>

    {/* Case Studies card */}
    <div class="flex flex-col gap-10 lg:flex-row">
      {
        caseStudies.caseStudiesItems.map((item) => (
          <CaseStudyCard id={item.id} title={item.title} image={item.image} />
        ))
      }
    </div>
  </container>
</section>
