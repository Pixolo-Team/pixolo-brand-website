---
// COMPONENTS //
import CaseStudyCard from "@/components/casestudy/CaseStudyCard.astro";
import ToolBadge from "@/components/ui/ToolBadge.astro";

// DATA //
import { caseStudySectionDetails } from "@/data/case-studies";
---

<section>
  <div
    class="container mx-auto flex flex-col gap-12 px-8 py-16 md:gap-14 md:px-0 md:py-16 lg:gap-16 lg:py-32"
  >
    {/* Header Section */}
    <div class="flex flex-col items-center gap-2.5 text-center md:gap-3.5 lg:gap-4">
      <!-- Tool Badge component -->
      <ToolBadge icon="puzzle-icon" text={caseStudySectionDetails.badgeTitle} />

      <!-- Title -->
      <p class="text-2xl leading-tight font-medium tracking-normal md:text-4xl lg:text-6xl">
        {caseStudySectionDetails.title}
      </p>
    </div>

    {/* Case Studies card */}
    <div class="grid grid-cols-1 gap-10 md:gap-16 md:px-16 lg:grid-cols-2 xl:grid-cols-3">
      {
        caseStudySectionDetails.caseStudyItems.map((caseStudyItem) => (
          <CaseStudyCard
            id={caseStudyItem.id}
            title={caseStudyItem.title}
            image={caseStudyItem.image}
          />
        ))
      }
    </div>
  </div>
</section>
