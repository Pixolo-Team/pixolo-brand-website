---
// COMPONENTS //
import TechBadge from "@/components/tech-interactive/TechBadge.astro";
import ToolBadge from "@/components/ui/ToolBadge.astro";

// DATA //
import { techInteractiveSectionDetails } from "@/data/tech-interactive";
---

<!-- Tech Interactive Section -->
<section id="tech-interactive-section">
  <!-- Container -->
  <div
    class="relative z-10 container mx-auto flex flex-col items-center justify-center gap-36 overflow-hidden px-6 pt-16 pb-72 md:gap-32 md:pt-36 md:pb-96 lg:pt-36 lg:pb-90"
  >
    <!-- Header -->
    <div class="flex flex-col items-center justify-center gap-6 md:px-16 lg:gap-7 lg:px-56">
      <!-- Tool Badge Component -->
      <div class="tool-badge">
        <ToolBadge
          icon={techInteractiveSectionDetails.badgeIcon}
          text={techInteractiveSectionDetails.badgeTitle}
        />
      </div>

      <!-- Title -->
      <p
        class="header-text text-n-950 text-center text-2xl leading-tight font-medium md:text-4xl lg:text-5xl"
      >
        {techInteractiveSectionDetails.title}
      </p>
    </div>

    <!-- Stats Wrapper -->
    <div class="flex flex-col flex-wrap">
      {
        techInteractiveSectionDetails.statItems.map((statText) => (
          <p class="tech-stat text-n-950 text-center text-4xl leading-tight font-medium tracking-[-0.04em] md:text-6xl lg:text-7xl">
            {statText}
          </p>
        ))
      }
    </div>

    <!-- Gravity Tech Badges Container -->
    <div id="tech-badge-container" class="absolute inset-0 z-0 overflow-hidden">
      {
        techInteractiveSectionDetails.techBadges.map((badge) => (
          <div class="tech-badge-wrapper absolute top-0 left-0 opacity-0">
            <TechBadge icon={badge.icon} text={badge.name} backgroundColor={badge.color} />
          </div>
        ))
      }
    </div>
  </div>
</section>
<style>
  .tech-stat {
    opacity: 0;
    transform: translateY(200px);
  }
</style>
<script>
  import {
    animateTechInteractiveSection,
    animateGravityEffect,
  } from "@/scripts/tech-interactive.ts";

  animateTechInteractiveSection();
  animateGravityEffect();
</script>
