---

<section>
  <div class="flex flex-col gap-10 overflow-x-auto md:flex-row">
    {
      miniProjectItems.map((miniProjectCardItem) => (
        <MiniProjectCard
          id={miniProjectCardItem.id}
          title={miniProjectCardItem.title}
          badgeText1={miniProjectCardItem.badgeOneText}
          badgeText2={miniProjectCardItem.badgeTwoText}
          date={miniProjectCardItem.date}
          btnOneText={miniProjectCardItem.btnOneText}
          btnTwoText={miniProjectCardItem.btnTwoText}
          image={miniProjectCardItem.image}
        />
      ))
    }
  </div>
</section>
