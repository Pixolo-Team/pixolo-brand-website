import MiniProjectCard from "@/components/portfolio/MiniProjectCard.astro";

const miniProjectItems = [
  {
    id: 1,
    title: "Football Club Barcelona",
    badgeOneText: "Online Course",
    badgeTwoText: "Online Course",
    date: "27 June 2024",
    btnOneText: "visit Website",
    btnTwoText: "Show Project",
    image: "default.jpg",
  },
  {
    id: 2,
    title: "Football Club Barcelona",
    badgeOneText: "Online Course",
    badgeTwoText: "Online Course",
    date: "27 June 2024",
    btnOneText: "visit Website",
    btnTwoText: "Show Project",
    image: "default.jpg",
  },
  {
    id: 3,
    title: "Football Club Barcelona",
    badgeOneText: "Online Course",
    badgeTwoText: "Online Course",
    date: "27 June 2024",
    btnOneText: "visit Website",
    btnTwoText: "Show Project",
    image: "default.jpg",
  },
