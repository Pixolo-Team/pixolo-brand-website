---
// COMPONENTS //
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";

// SVG's //
import Ball3D from "src/assets/3d-ball.svg";

const tagTitle = "Crafted Highlights";
const mainHeading = "A show case of the work that defines our creativity and craft";
const subHeading = "A dynamic showcase where every build sparks innovation";

export { tagTitle, mainHeading, subHeading };
---

<!-- Hero Section -->
<section>
  <!-- Container -->
  <div class="relative container mx-auto px-6 py-24 text-center md:gap-9 md:py-40 lg:gap-12">
    <!-- 3D Ball -->
    <div class="absolute inset-0 z-[-1]">
      <div
        class="absolute top-[278px] left-[65px] h-9 w-9 md:top-[400px] md:left-[200px] md:h-16 md:h-20 md:w-16 md:w-20 xl:top-[330px] xl:left-[120px]"
      >
        <Image src={Ball3D} alt={"3d big ball image"} class={"w-full"} />
      </div>
      <div
        class="absolute top-[145px] left-[252.47px] h-5 w-5 rotate-[-22.29deg] md:top-[450px] md:left-[780px] md:h-11 md:h-12 md:w-11 md:w-12 xl:top-[300px] xl:left-[1200px]"
      >
        <Image src={Ball3D} alt={"3d small ball image"} class={"w-full"} />
      </div>
    </div>

    <!-- Content -->
    <div class="flex flex-col items-center gap-8 md:gap-9 lg:gap-10">
      <!-- Pill -->
      <div
        class="border-n-950 flex items-center gap-2.5 rounded-3xl border py-1.5 pr-4 pl-1.5 md:gap-3 lg:gap-4 lg:pr-5"
      >
        <!-- Comment Icon -->
        <div
          class="flex h-7 w-7 items-center justify-center gap-10 rounded-3xl bg-blue-500 p-2 md:h-8 md:w-8 lg:h-10 lg:w-10"
        >
          <Icon name="comment" />
        </div>

        <!-- Tag Title -->
        <p
          class="text-n-900 text-center text-xs leading-none font-medium tracking-normal md:text-base lg:text-lg"
        >
          {tagTitle}
        </p>
      </div>

      <!-- Headings -->
      <div class="flex flex-col gap-3.5 lg:gap-7">
        <!-- Main heading -->
        <p class="text-3xl leading-tight font-medium tracking-[-1] md:text-5xl lg:text-7xl">
          {mainHeading}
        </p>

        <!-- Subheading -->
        <p
          class="bg-[linear-gradient(90deg,var(--blue-500)_0%,var(--blue-300)_100%))] bg-clip-text text-sm leading-tight tracking-normal text-transparent md:text-lg lg:text-2xl"
        >
          {subHeading}
        </p>
      </div>
    </div>
  </div>
</section>
