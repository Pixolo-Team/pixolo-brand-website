---
import ToolBadge from "@/components/ToolBadge.astro";
import TeamCard from "@/components/TeamCard.astro";
import SliderArrows from "@/components/ui/SliderArrows.astro";
import EmblaCarousel from "embla-carousel";
import { initIndustrySlider } from "@/scripts/industries.ts";

interface TeamMember {
  name: string;
  role: string;
  image: string;
}

const featuredMembers: TeamMember[] = [
  {
    name: "Harsh Patil",
    role: "Product Manager",
    image: "/images/portfolio/image-video.svg",
  },
  {
    name: "Harsh Patil",
    role: "Product Manager",
    image: "/images/portfolio/image-video.svg",
  },
];

const moreTeamMembers: TeamMember[] = [
  {
    name: "Harsh Patil",
    role: "Product Manager",
    image: "/images/portfolio/image-video.svg",
  },
  {
    name: "Elena Tran",
    role: "UX Designer",
    image: "/images/portfolio/image-video.svg",
  },
  {
    name: "Rajesh Kumar",
    role: "Frontend Developer",
    image: "/images/portfolio/image-video.svg",
  },
  {
    name: "Maya Singh",
    role: "Backend Developer",
    image: "/images/portfolio/image-video.svg",
  },
  {
    name: "Liam Chen",
    role: "QA Engineer",
    image: "/images/portfolio/image-video.svg",
  },
  {
    name: "Sophia Lee",
    role: "Marketing Specialist",
    image: "/images/portfolio/image-video.svg",
  },
];
---

<section>
  <!-- OUTER CONTAINER -->
  <div
    class="container mx-auto flex w-full max-w-screen-2xl flex-col gap-16 px-6 py-20 md:py-24 xl:gap-16 xl:py-28"
  >
    <!-- TEAM CONTAINER -->
    <div class="flex w-full flex-col gap-12">
      <!-- HEADER -->
      <div class="flex w-full flex-col items-center gap-4 text-center">
        <ToolBadge icon="service-icon" text="Meet the Team" />

        <p
          class="anim-fade-in-up text-n-950 text-3xl leading-[125%] font-normal md:text-4xl xl:text-5xl"
        >
          Behind the Scenes With Our Creative & Dev Crew
        </p>
      </div>

      <!-- CONTENT WRAP -->
      <div class="flex w-full flex-col gap-4 xl:gap-7">
        <!-- FEATURED MEMBER -->
        <div class="flex w-full flex-col gap-10 md:gap-12 lg:gap-7">
          <!-- FEATURED CAROUSEL -->
          <div id="featured-carousel" class="overflow-hidden flex gap-4 xl:gap-5">
            {
              featuredMembers.map((member, index) => (
                <div
                  class={`custom-cursor anim-fade-up-slow w-full shrink-0 xl:w-260.5`}
                  style={`animation-delay: ${index * 120}ms`}
                >
                  <TeamCard poster={member.image} name={member.name} role={member.role} />
                </div>
              ))
            }
          </div>
        </div>

        <!-- FEATURED ARROWS -->
        <div class="flex justify-end">
          <SliderArrows prevId="featured-prev" nextId="featured-next" />
        </div>

        <!-- MORE TEAM -->
        <div class="flex w-full flex-col gap-6">
          <p class="text-n-950 text-xl leading-[125%] font-normal md:text-2xl">
            Meet More of the Team
          </p>

          <!-- SMALL CAROUSEL -->
          <div id="small-carousel" class="overflow-hidden">
            <div class="flex gap-4">
              {
                moreTeamMembers.map((member, index) => (
                  <div
                    class="flex w-57.25 shrink-0 flex-col gap-3.5 md:w-57.25 xl:w-[291.2px]"
                    style={`--delay: ${index * 0.15}s`}
                  >
                    <img
                      src={member.image}
                      alt={member.name}
                      class="h-49.5 w-full rounded-2xl object-cover"
                    />

                    <div class="flex flex-col gap-0.5 px-2.5">
                      <p class="text-n-950 text-xl leading-[125%]">{member.name}</p>
                      <p class="text-n-700 text-sm leading-[125%]">{member.role}</p>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>

          <!-- SMALL ARROWS -->
          <div class="flex justify-end">
            <SliderArrows prevId="small-prev" nextId="small-next" />
          </div>
        </div>
      </div>
    </div>
  </div>
  <div
    id="team-hover-cursor"
    class="bg-n-200 pointer-events-none fixed z-50 hidden -translate-x-1/2 -translate-y-1/2 rounded-xl px-3 py-1.5"
  >
    <p class="text-n-950 text-xs whitespace-nowrap">Watch Video</p>
  </div>
</section>

<!-- CAROUSEL LOGIC -->

<script>
  import { initSlider } from "@/scripts/portfolio-consumption/slider";

  document.addEventListener("DOMContentLoaded", () => {
    initSlider({
      sliderId: "featured-carousel",
      prevId: "featured-prev",
      nextId: "featured-next",
      loop: true,
    });

    initSlider({
      sliderId: "small-carousel",
      prevId: "small-prev",
      nextId: "small-next",
      loop: false,
    });
  });
  import { animateHoverFollowCursor } from "@/scripts/hover-follow-cursor";

  document.addEventListener("DOMContentLoaded", () => {
    animateHoverFollowCursor({
      targetSelector: ".team-card-hover",
      cursorId: "team-hover-cursor",
    });
  });
</script>
