---
import TeamCard from "@/components/TeamCard.astro";

interface Member {
  video: string;
  name: string;
  role: string;
}

const team: Member[] = [
  { video: "/videos/stars.mp4", name: "Asha Kumar", role: "Founder & CEO" },
  { video: "/videos/stars.mp4", name: "Liam Park", role: "CTO" },
  { video: "/videos/stars.mp4", name: "Maya Singh", role: "Head of Design" },
];
---

<section aria-label="Team" class="grid gap-6 md:grid-cols-3">
  {team.map((member) => <TeamCard video={member.video} name={member.name} role={member.role} />)}
</section>
