---
// COMPONENTS //
import SliderArrows from "@/components/portfolio/SliderArrows.astro";
import ServiceItem from "@/components/ServiceItem.astro";
import ToolBadge from "src/components/ToolBadge.astro";

// DATA //
import { portfolioIndustryDetails } from "src/data/portfolio/industries.ts";
---

<!-- Industries Section -->
<section>
  <!-- Container -->
  <div
    class="container mx-auto flex flex-col justify-center gap-9 px-6 py-16 md:gap-12 md:p-24 lg:gap-14 lg:p-28"
  >
    <!-- Tool Badge and Heading -->
    <div class="flex flex-col items-center gap-3.5 text-center md:gap-4 lg:gap-3.5">
      <!-- Tool Badge -->
      <div class="flex flex-col items-center gap-8 md:gap-9 lg:gap-10">
        <ToolBadge icon="comment" text={portfolioIndustryDetails.badgeTitle} />
      </div>

      <!-- Heading -->
      <p
        class="text-n-950 text-3xl leading-tight font-normal tracking-[-2%] md:text-5xl lg:text-6xl"
      >
        {portfolioIndustryDetails.title}
      </p>
    </div>

    <!-- Cards and arrows -->
    <div class="group relative flex flex-col gap-8 md:gap-10 lg:items-end">
      <!-- Cards -->
      <div
        id="industry-slider"
        class="hide-scrollbar flex snap-x snap-mandatory gap-6 overflow-x-auto md:gap-8 lg:flex lg:snap-x"
      >
        {
          portfolioIndustryDetails.industryItems.map((industryItem) => (
            <div class="flex min-w-[100%] snap-start justify-center md:min-w-[70%] lg:min-w-[33.333%]">
              <ServiceItem
                title={industryItem.title}
                imageName={industryItem.image}
                tags={industryItem.tags}
              />
            </div>
          ))
        }
      </div>

      <!-- Arrows -->
      <SliderArrows />
    </div>
  </div>
</section>

<!-- Hiding horizontal scroll -->
<style>
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }

  .hide-scrollbar {
    scrollbar-width: none;
  }
</style>

<!-- Button working logic -->
<script>
  import "src/scripts/industries.ts";
</script>
