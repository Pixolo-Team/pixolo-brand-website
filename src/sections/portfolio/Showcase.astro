---
import ProjectShowcaseCard from "@/components/portfolio/showcase/ProjectShowcaseCard.astro";
import MiniProjectCard from "@/components/portfolio/showcase/MiniProjectCard.astro";
import ToolBadge from "@/components/ui/ToolBadge.astro";
import SliderArrows from "@/components/ui/SliderArrows.astro";
import { Icon } from "astro-icon/components";
import { portfolioShowcaseDetails } from "@/data/portfolio/showcase";
import { getPortfolioShowcaseDataRequest } from "@/services/api/portfolio-showcase.api";
import type { PortfolioShowcaseData } from "@/types/portfolio-showcase.types";

const portfolioShowcaseData: PortfolioShowcaseData[] = await getPortfolioShowcaseDataRequest();
console.log(portfolioShowcaseData);
---

<!-- Portfolio Showcase Section -->
<section id="showcase-section">
  <!-- Container -->
  <div
    class="container mx-auto flex flex-col items-center justify-center gap-8 px-6 py-16 md:gap-11 md:py-20 lg:gap-14 lg:py-16"
  >
    <!-- Header -->
    <div class="flex flex-col items-center justify-center gap-4">
      <!-- Toolbadge -->
      <div class="tool-badge">
        <ToolBadge
          icon={portfolioShowcaseDetails.sectionHeader.badgeIcon}
          text={portfolioShowcaseDetails.sectionHeader.badgeTitle}
        />
      </div>

      <!-- Title -->
      <p
        id="header-text"
        class="text-n-950 text-center text-2xl leading-tight font-normal tracking-[-2%] md:text-4xl lg:text-6xl"
      >
        {portfolioShowcaseDetails.sectionHeader.title}
      </p>
    </div>

    <!-- Portfolio Wrap -->
    <div class="flex max-w-full flex-col gap-10 md:gap-24 lg:gap-32">
      <!-- Portfolio Project Tiles -->
      <div class="flex flex-col gap-10">
        <!-- Tiles -->
        <div class="hidden justify-end gap-4 px-8 md:flex lg:gap-5">
          <!-- List Icon Button-->
          <button id="listIconBtn" class="cursor-pointer">
            <!-- Icon -->
            <Icon
              name={"list"}
              class={`text-n-500 size-5 lg:size-6 hover:scale-120 transition duration-200 ease-in-out`}
            />
          </button>

          <!-- Grid Icon Button-->
          <button id="gridIconBtn" class="cursor-pointer">
            <!-- Icon -->
            <Icon
              name={"grid"}
              class={`size-5 lg:size-6 hover:scale-120 transition duration-200 ease-in-out`}
            />
          </button>
        </div>

        <!-- Portfolio Cards Wrap -->
        <div
          id="portfolio-project-cards"
          data-view="list"
          class={`group grid grid-cols-1 data-[view=grid]:md:grid-cols-2 gap-10`}
        >
          {
            // Project Cards //
            portfolioShowcaseData
              .filter(
                (projectCard) =>
                  projectCard.show_in_home === "FALSE" && projectCard.is_highlight === "TRUE",
              )

              .map((projectCard) => (
                <ProjectShowcaseCard
                  id={projectCard.id}
                  name={projectCard.brand_name}
                  image={
                    projectCard.thumbnail_image
                      ? projectCard.thumbnail_image
                      : "/images/default-showcase-project-image.jpg"
                  }
                  title={projectCard.title}
                  subTitle={projectCard.subtitle}
                  description={projectCard.subtitle}
                  date={""}
                  tagItems={projectCard.badges}
                />
              ))
          }
        </div>
      </div>

      <!-- Mini Projects Wrap -->
      <div
        id="portfolio-mini-project-cards"
        data-view="list"
        class="group embla flex flex-col gap-8 overflow-hidden md:gap-12 lg:gap-16"
      >
        <!-- Mini Projects Content -->
        <div class="flex flex-col gap-5 md:gap-6 lg:gap-7">
          <!-- Title -->
          <p
            class="text-n-950 text-base leading-tight font-normal md:text-2xl group-data-[view=list]:md:text-xl group-data-[view=list]:lg:text-2xl"
          >
            Mini Projects
          </p>

          <!-- Cards Wrap -->
          <div id="showcase-slider" class="embla__viewport">
            <!-- Embla container -->
            <div class="embla__container flex gap-6">
              <!-- Iterating on Project Cards -->
              {
                portfolioShowcaseData
                  .filter((cardItem) => cardItem.is_highlight === "FALSE")
                  .map((cardItem) => (
                    // Mini Project Cards
                    <div class="embla__slide w-full shrink-0 sm:max-w-[328px] lg:max-w-[412px]">
                      <MiniProjectCard
                        id={cardItem.id}
                        title={cardItem.brand_name}
                        tagItems={cardItem.badges}
                        date={""}
                        image={
                          cardItem.thumbnail_image
                            ? cardItem.thumbnail_image
                            : "/images/default-showcase-project-image.jpg"
                        }
                      />
                    </div>
                  ))
              }
            </div>
          </div>
        </div>

        <!-- Slider Cta Wrap -->
        <div class="relative flex max-w-full flex-col">
          <!-- Cta Wrap -->
          <div class="self-end">
            <SliderArrows />
          </div>

          <!-- Slider -->
          <div
            class="border-n-500 absolute inset-y-0 h-0 w-24 self-center border md:w-36 md:border-2 lg:w-96"
          >
            <div
              id="embla__progress__bar"
              class="absolute -top-px h-0 w-0 border border-blue-500 md:border-2"
            >
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import {
    animateShowcaseSection,
    initShowcase,
    initShowcaseSlider,
    animateProjectCards,
  } from "@/scripts/showcase";

  document.addEventListener("DOMContentLoaded", () => {
    initShowcase();
    initShowcaseSlider();
    animateShowcaseSection();
    animateProjectCards();
  });
</script>
