---
// COMPONENTS //
import ToolBadge from "@/components/ui/ToolBadge.astro";
import Tabs from "@/components/ui/Tabs.astro";
import RoundedButton from "@/components/ui/RoundedButton.astro";
import BlogCard from "@/components/blogs/BlogCard.astro";

// DATA //
import { blogListingDetails } from "@/data/blog-listing/blog-listing";
import type { BlogItemData, BlogListingData } from "@/types/blogs-listing";
import { URLS } from "@/infrastructure/constants/urls";
import { getBlogsRequest } from "@/services/api/blogs.api";

/** Makes an API Call to fetch blogs data */
const blogsList: any = await getBlogsRequest();
---

<!-- Blog-Listing Section -->
<section id="blogs-listing-section">
  <!-- Container -->
  <div class="container mx-auto grid grid-cols-1 gap-9 px-6 py-28 lg:gap-16 lg:py-30">
    <!-- Header Section -->
    <div class="grid grid-cols-1 gap-3 md:gap-4 lg:gap-5">
      <!-- Tool Badge -->
      <div class="tool-badge justify-self-start">
        <ToolBadge icon={blogListingDetails.icon} text={blogListingDetails.badgeTitle} />
      </div>
      <!-- Heading -->
      <h2
        id="header-text"
        class="text-n-950 text-3xl leading-tight font-normal tracking-tighter md:text-4xl lg:text-5xl"
      >
        {blogListingDetails.heading}
      </h2>
    </div>
    <!-- Body Section: Tabs and Blog Cards -->
    <div class="body-section grid grid-cols-1 gap-5 md:gap-7">
      <!-- Tabs -->
      <div class="tabs-wrapper">
        <Tabs tabItems={blogListingDetails.tabsItems} />
      </div>

      <!-- Blog-Cards-Wrapper -->
      <div id="blog-cards-wrap" class="grid grid-cols-1 gap-11 md:gap-16">
        <!-- Blog-Card -->
        <div id="blog-cards" class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:gap-9 xl:grid-cols-3">
          {
            // Blog-Card
            blogsList.map((blogItem: BlogItemData) => (
              <div
                class="blog-card-item"
                data-category={blogItem.category?.toLowerCase() || "uncategorized"}
              >
                <BlogCard
                  imageSrc={blogItem.imageSrc || blogListingDetails.defaultImage}
                  category={blogItem.category ? blogItem.category : ""}
                  date={blogItem.date}
                  title={blogItem.title}
                  author={blogItem.author}
                  href={URLS.BLOGS.ITEM(blogItem.title.replaceAll(" ", "-").toLowerCase())}
                />
              </div>
            ))
          }
        </div>
        <!-- LoadMore Button -->
        <div class="justify-self-center">
          <RoundedButton
            id="load-more-btn"
            buttonText="Load More Blogs"
            type="button"
            variant="tertiary"
          />
        </div>
      </div>
    </div>
  </div>
</section>
<script>
  // OTHERS //
  import { initLoadMore } from "@/scripts/load-more";
  import { animateBlogsListingSection } from "@/scripts/blogs-listing";
  animateBlogsListingSection();
  const CONFIG = {
    containerId: "blog-cards",
    loadMoreBtnId: "load-more-btn",
    cardClass: "blog-card-item",
    initialVisible: {
      desktop: 6,
      tablet: 4,
      mobile: 3,
    },
    incrementConfig: {
      desktop: 6,
      tablet: 2,
      mobile: 3,
    },
  };
  /** Initialize blog load more functionality */
  const setupBlogs = () => {
    initLoadMore(CONFIG);
  };
  // Run on first page load
  document.addEventListener("DOMContentLoaded", setupBlogs);

  // Run again after Astro View Transitions navigation
  document.addEventListener("astro:page-load", setupBlogs);

  const filterBlogsByActiveTab = (tabId) => {
    const cards = document.querySelectorAll(".blog-card-item");

    cards.forEach((card) => {
      const cardCategory = card.dataset.category;

      if (tabId === "all" || cardCategory === tabId) {
        card.style.display = "";
      } else {
        card.style.display = "none";
      }
    });
  };

  const setupTabFiltering = () => {
    const tabsContainer = document.getElementById("tabs-container");
    if (!tabsContainer) return;

    const tabs = tabsContainer.querySelectorAll("button[data-tab-id]");

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const tabId = tab.dataset.tabId.toLowerCase();

        filterBlogsByActiveTab(tabId);

        // re-init load more for filtered results
        initLoadMore(CONFIG);
      });
    });

    // Apply filter on initial active tab
    const activeTab = tabsContainer.querySelector(".bg-n-950");
    if (activeTab) {
      filterBlogsByActiveTab(activeTab.dataset.tabId.toLowerCase());
    }
  };

  document.addEventListener("DOMContentLoaded", setupTabFiltering);
  document.addEventListener("astro:page-load", setupTabFiltering);
</script>
