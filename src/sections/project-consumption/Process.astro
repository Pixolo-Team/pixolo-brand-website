---
// COMPONENTS //
import ProcessStepItem from "@/components/project-consumption/ProcessStepItem.astro";
import ToolBadge from "@/components/ui/ToolBadge.astro";
import type { PortfolioProcessItem } from "@/types/portfolio";

interface Props {
  processItems: PortfolioProcessItem[];
}

const { processItems } = Astro.props as Props;
---

<!-- Project Consumption Process Section -->
<section id="project-consumption-process-section">
  <!-- Container -->
  <div
    class="container mx-auto flex flex-col gap-12 px-6 py-16 md:gap-14 md:py-24 lg:gap-16 lg:py-28"
  >
    <div class="flex flex-col items-center gap-3 md:gap-4">
      <!-- ToolBadge Component -->
      <div class="tool-badge">
        <ToolBadge icon="service-icon" text={"Process"} />
      </div>

      <!-- Title -->
      <p
        class="header-text text-n-950 text-center text-3xl leading-tight font-normal tracking-[-2px] md:text-4xl lg:text-5xl"
      >
        {"How We Make It Happen"}
      </p>
    </div>

    <!-- Steps Items -->
    <div class="scroll-line relative flex flex-col items-center gap-48 md:gap-72">
      {
        processItems.map((stepItem, stepItemIndex) => (
          <ProcessStepItem title={stepItem.title} description={stepItem.description} />
        ))
      }
    </div>
  </div>
  <style>
    .scroll-line::before,
    .scroll-line::after {
      content: "";
      position: absolute;
      top: 0;
      width: 6px;
      transform: translateX(-50%);
      border-radius: 999px;
      left: 44px;
    }

    .scroll-line::before {
      height: 100%;
      background: var(--color-n-300);
      z-index: -2;
    }

    .scroll-line::after {
      height: var(--fill-height, 0%);
      background: linear-gradient(var(--color-blue-500), #8b77f3);
      z-index: -1;
      transition: height 150ms linear;
    }

    @media (min-width: 768px) {
      .scroll-line::before {
        left: 50%;
      }

      .scroll-line::after {
        left: 50%;
      }
    }
  </style>
  <script>
    import { animateProjectConsumptionProcessSection } from "@/scripts/portfolio-consumption/process";
    import { initScrollLine } from "@/utils/scroll-line";

    initScrollLine();

    animateProjectConsumptionProcessSection();
  </script>
</section>
