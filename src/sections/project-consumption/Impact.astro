---
// COMPONENTS //
import ToolBadge from "@/components/ui/ToolBadge.astro";
import StatBox from "@/components/project-consumption/StatBox.astro";

// DATA //
import { impactContent } from "@/data/portfolio/project-consumption/impact";
---

<!-- Impact Section -->
<section id="impact-section">
  <!-- Container -->
  <div
    class="container mx-auto flex flex-col gap-10 px-6 py-16 md:gap-16 md:px-0 md:py-20 lg:gap-20 lg:py-28"
  >
    <!-- Tool Badge and Heading -->
    <div class="flex flex-col items-center gap-3.5 md:gap-4">
      <!-- Tool Badge -->
      <div class="tool-badge">
        <ToolBadge icon={impactContent.badgeIcon} text={impactContent.badgeText} />
      </div>
      
      <!-- Heading -->
      <p
        id="header-text"
        class="w-full text-center text-3xl leading-tight font-normal tracking-[-0.02em] md:text-4xl lg:text-5xl"
      >
        {impactContent.heading}
      </p>
    </div>
    <!-- StatsRows -->
    <div class="stat-boxes grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4">
      {
        impactContent.stats.map((statItem, index) => (
          <StatBox statValue={statItem.statValue} title={statItem.title} index={index} />
        ))
      }
    </div>
  </div>
</section>

<script>
  import { animateImpactSection } from "@/scripts/portfolio-consumption/impact.ts";

  // Animate Impact Section
  animateImpactSection();
</script>
