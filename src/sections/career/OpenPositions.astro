---
// COMPONENTS //
import ToolBadge from "@/components/ui/ToolBadge.astro";
import OpenPositionCard from "@/components/career/OpenPositionCard.astro";

// DATA //
import { openPositions } from "@/data/career/open-positions";
---

<!-- Open Positions Section -->
<section id="open-positions-section">
  <!-- Container -->
  <div
    class="container mx-auto flex flex-col gap-9 px-6 py-16 md:gap-11 md:py-24 lg:gap-14 lg:py-28"
  >
    <!-- ToolBadge and Title -->
    <div class="flex flex-col items-center gap-4 self-center text-center lg:w-[75%] lg:gap-5">
      <!-- ToolBadge -->
      <div class="tool-badge">
        <ToolBadge icon={openPositions.toolBadgeIcon} text={openPositions.toolBadgeText} />
      </div>

      <!-- Title -->
      <p
        id="open-positions-heading"
        class="font-regular text-2xl leading-tight tracking-[-0.02em] md:text-4xl lg:text-5xl"
      >
        {openPositions.title}
      </p>
    </div>

    <!-- Cards -->
    <div
      class="open-position-cards grid grid-cols-1 gap-4 md:grid-cols-2 lg:gap-6 xl:gap-10 2xl:grid-cols-3"
    >
      {
        openPositions.positions.map((position) => (
          // Open Position Card Component
          <div class="open-position-card">
            <OpenPositionCard
              category={position.category}
              title={position.title}
              tags={position.tags}
              ctaText="Apply Now"
            />
          </div>
        ))
      }
    </div>
  </div>
</section>
<script>
  import { animateOpenPositionsSection } from "@/scripts/career/open-positions";

  animateOpenPositionsSection();
</script>
