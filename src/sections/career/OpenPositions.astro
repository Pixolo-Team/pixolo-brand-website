---
// COMPONENTS //
import ToolBadge from "@/components/ui/ToolBadge.astro";
import OpenPositionCard from "@/components/open-positions/OpenPositionCard.astro";

// DATA //
import { openPositions } from "@/data/career/open-positions";
---

<!-- Open Positions Section -->
<section>
  <!-- Container -->
  <div
    class="container mx-auto flex flex-col gap-9 px-6 py-16 md:gap-11 md:px-0 md:py-24 lg:gap-14 lg:py-28"
  >
    <!-- ToolBadge and Title -->
    <div class="flex  lg:w-[75%] flex-col items-center gap-4 self-center text-center lg:gap-5">
      <!-- TollBagde -->
      <ToolBadge icon={openPositions.toolBadgeIcon} text={openPositions.toolBadgeText} />

      <!-- Title -->
      <p
        class="open-positions-heading font-regular text-2xl leading-tight tracking-[-0.02em] md:text-4xl lg:text-5xl"
      >
        {openPositions.title}
      </p>
    </div>

    <!-- Cards -->
    <div class="flex flex-wrap justify-center gap-4 lg:gap-10">
      {
        openPositions.positions.map((position, index) => (
          // Card
          <div
            class="open-positions-card md:min-w-[360px] lg:min-w-[480px] flex-shrink-0 min-w-[327px]"
            style={`--delay: ${index * 0.3}s`}
          >
            <OpenPositionCard
              category={position.category}
              title={position.title}
              tags={position.tags}
              ctaText={position.ctaText}
            />
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
<script src="src/scripts/career/open-positions.ts" is:inline></script>
