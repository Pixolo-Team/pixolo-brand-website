---
// COMPONENTS //
import ToolBadge from "@/components/ui/ToolBadge.astro";
import BelongingStatementCard from "@/components/career/belonging-statement/BelongingStatementCard.astro";

// DATA //
import { belongingStatement } from "@/data/career/belonging-statement";
---

<!-- Belonging Section -->
<section id="belonging-section">
  <!-- Container -->
  <div
    class="container mx-auto flex flex-col gap-8 px-6 py-14 md:gap-11 md:py-20 lg:gap-16 lg:py-28"
  >
    <!-- ToolBagde and Title -->
    <div class="flex flex-col items-center gap-3.5 text-center md:gap-4">
      <!-- ToolBagde -->
      <div class="tool-badge-anim">
        <ToolBadge icon={belongingStatement.toolBadgeIcon} text={belongingStatement.toolBadgeText} />
      </div>

      <!-- Title -->
      <p class="heading-anim font-regular text-3xl leading-tight tracking-[-0.02em] md:text-4xl lg:text-5xl">
        {belongingStatement.title}
      </p>
    </div>

    <!-- Cards -->
    <div class="grid grid-cols-1 gap-8 md:gap-16 lg:grid-cols-2">
      {
        belongingStatement.belongingStatementCard.map((belongingStatementCardItem) => (
          // Card
          <div class="belonging-card opacity-0 lg:max-w-[735px]">
            <BelongingStatementCard {...belongingStatementCardItem} />
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  import { animateBelongingSection } from "@/scripts/career/belonging-statement";

  animateBelongingSection();
</script>
