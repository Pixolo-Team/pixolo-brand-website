---
// COMPONENTS //
import ToolBadge from "@/components/ui/ToolBadge.astro";
import { Image } from "astro:assets";

// DATA //
import { reasonToWorkWithUs, headingsAndDetails } from "@/data/career/why-work-with-us";
---

<!-- Why Work With Us Section -->
<section id="why-work-section">
  <!-- Container -->
  <div
    class="container mx-auto flex flex-col gap-10 px-6 py-16 md:gap-14 md:px-0 md:py-24 lg:gap-16 lg:py-28"
  >
    <!-- Header Section -->
    <div class="flex flex-col items-center gap-3.5 md:gap-5">
      <div class="tool-badge">
        <ToolBadge icon="package" text={headingsAndDetails.badgeText} />
      </div>
      <p
        id="header-text"
        class="text-center text-2xl leading-tight font-normal tracking-[-0.02em] md:text-4xl lg:text-5xl"
      >
        {headingsAndDetails.mainTitle}
      </p>
    </div>
    <!-- Content Wrap -->
    <div class="mx-auto flex w-full flex-col gap-9 md:gap-12 lg:flex-row lg:gap-14">
      <!-- Image -->
      <div
        id="team-image"
        class="h-[50%] w-full overflow-hidden rounded-4xl md:h-[110%] lg:w-[104%]"
      >
        <Image
          src={headingsAndDetails.image}
          width={1200}
          height={500}
          alt={"why-work-with-us-default"}
          class={" w-full h-full  object-cover"}
        />
      </div>
      <!-- Content -->
      <div class="flex w-full flex-col gap-5 md:gap-6 lg:gap-7">
        {
          reasonToWorkWithUs.map((reason, index) => (
            // Why-us
            <div
              class="work-reason-item flex w-full items-start justify-between gap-2.5"
              style={`animation-delay: ${index * 500}ms`}
            >
              {/* Number Text */}
              <span class="flex shrink-0 flex-col self-end text-lg leading-relaxed font-normal tracking-[-0.02em] capitalize md:text-2xl lg:text-3xl">
                {reason.id}
              </span>

              {/* Header-SubHeader */}
              <div class="flex flex-1 flex-col gap-4">
                {/* Big Text */}
                <div class="border-n-700 flex w-full flex-col border-b py-3 pr-1.5 md:px-3 md:pr-4 lg:pl-8">
                  <p class="text-n-700 text-right text-base leading-tight font-normal tracking-normal capitalize md:text-xl lg:text-2xl">
                    {reason.title}
                  </p>
                </div>

                {/* Hidden Text */}
                <p class="hidden text-right text-lg leading-tight font-normal tracking-normal text-white not-italic">
                  {reason.hiddeTitle}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
<!-- Script for Animation -->
<script>
  import { animateWhyWorkWithUs } from "@/scripts/career/why-work-with-us";
  animateWhyWorkWithUs();
</script>
