---
// COMPONENTS //
import ToolBadge from "@/components/ui/ToolBadge.astro";

// SVG's //
import Ball from "@/assets/3d-ball.svg";

// DATA //
import { careerHeroDetails } from "@/data/career/hero";

import { Image } from "astro:assets";
---

<!-- Career-Hero Start -->
<section>
  <div
    class="relative container mx-auto gap-12 px-6 py-24 md:px-0 lg:pt-72 lg:pr-36 lg:pb-60 lg:pl-48"
  >
    <!-- Top-left floating marble -->
    <Image
      id="big-marble"
      src={Ball}
      alt="Big Marble"
      class="absolute top-[37%] left-4 w-5 md:top-[87%] md:left-50 md:w-16 lg:top-[54%] lg:left-5 lg:w-20"
    />

    <!-- Bottom-right floating marble -->
    <Image
      id="small-marble"
      src={Ball}
      alt="Small Marble"
      class="absolute right-[6%] bottom-[29%] w-9 rotate-[-20deg] md:right-[10%] md:bottom-[15%] md:w-11 lg:right-[25%] lg:bottom-[46%] lg:w-12"
      style="animation-duration: 4s"
    />

    <!-- Content  -->
    <div class="flex flex-col items-center gap-8 md:gap-9 lg:gap-10">
      <ToolBadge icon="comment" text="Build Your Future With Us" />
      <div class="z-10 flex flex-col items-center gap-3.5 md:gap-6 lg:gap-7">
        <p
          class="flex-wrap text-center text-3xl leading-tight font-medium tracking-[-0.01em] md:text-6xl lg:text-7xl"
        >
          {careerHeroDetails.heading}
        </p>
        <p
          class="bg-gradient-to-r from-[#4254D4] to-[#8B77F3] bg-clip-text text-center text-base leading-tight font-medium tracking-normal text-transparent md:text-xl lg:text-2xl"
        >
          {careerHeroDetails.subHeading}
        </p>
      </div>
    </div>
  </div>
</section>
