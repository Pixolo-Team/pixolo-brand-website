---
// COMPONENTS //
import ClientIssues from "@/components/case-studies/ClientIssue.astro";

// Receive data from the parent page
interface props {
  clientIssuesHeading: string;
  clientIssues: {
    title: string;
    description: string;
    issue: string;
    stat: string;
  }[];
}
const { clientIssuesHeading = "", clientIssues = [] } = Astro.props as props;
---

{
  clientIssues.length > 0 && (
    // Client Issues Section
    <section>
      {/* Container  */}
      <div class="container mx-auto flex flex-col gap-11 px-6 py-16 md:gap-14 md:py-20 lg:gap-16 lg:py-24">
        {/* Section Title  */}
        {clientIssuesHeading !== "" && (
          <p class="text-n-800 text-center text-3xl leading-tight font-medium md:text-5xl">
            {clientIssuesHeading}
          </p>
        )}

        {/* Issue Component */}
        <div class="flex flex-col gap-5">
          {/* Iterating through data */}
          {clientIssues?.map((clientIssueItem: any) => (
            <ClientIssues
              title={clientIssueItem.title}
              description={clientIssueItem.description}
              issue={clientIssueItem.issue}
              stat={clientIssueItem.stat}
            />
          ))}
        </div>
      </div>
    </section>
  )
}
