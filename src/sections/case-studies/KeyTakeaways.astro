---
import SectionHeader from "@/components/ui/SectionHeader.astro";
import LearningCard from "@/components/case-studies/LearningCard.astro";

const { data } = Astro.props;
---

<!-- Key Takeaways Section -->
<section id="key-takeaways-section">
  <!-- Container  -->
  <div
    class="container mx-auto flex flex-col justify-center gap-10 px-6 py-16 md:gap-11 md:py-24 lg:gap-16 lg:py-28"
  >
    <!-- Section Header -->
    <SectionHeader sectionTitle={data.title} badgeIcon="service-icon" badgeText={data.toolbadge} />

    <div class="flex w-full flex-col gap-9 lg:gap-20">
      <!-- Iterating through Learning Cards -->
      {
        data.takeaways.map((takeawayItem: any, takeawayItemIndex: number) => (
          // Learning Card Component
          <div class="learning-item-card">
            <LearningCard
              title={takeawayItem.title}
              description={takeawayItem.description}
              number={String(takeawayItemIndex + 1).padStart(2, "0")}
            />
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  import { animateKeyTakeawaySection } from "@/scripts/case-studies";
  animateKeyTakeawaySection();
</script>
