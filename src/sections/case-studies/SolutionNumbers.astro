---
// COMPONENTS //
import ClientIssues from "@/components/case-studies/ClientIssue.astro";

// Receive data from the parent page
interface props {
  solutionNumbers: {
    title: string;
    description: string;
    issue: string;
    stat: string;
  }[];
}
const { solutionNumbers } = Astro.props;
---

{
  solutionNumbers.length > 0 && (
    // Solution Numbers Section
    <section id="solution-numbers">
      {/* Container */}
      <div class="container mx-auto flex flex-col gap-9 px-6 py-16 md:gap-11 md:py-24 lg:gap-12 lg:py-28">
        {/* Title */}
        <p
          id="solution-numbers-header"
          class="text-center text-2xl leading-tight md:text-3xl lg:text-4xl"
        >
          Limitations That Guided the Process
        </p>

        {/* Solution Numbers */}
        <div id="sol-num-wrap" class="flex flex-col gap-5">
          {/* Iterate through Data  */}
          {solutionNumbers?.map((limitationItem: any) => (
            <ClientIssues
              title={limitationItem.title}
              description={limitationItem.description}
              issue={limitationItem.issue}
              stat={limitationItem.stat}
            />
          ))}
        </div>
      </div>
    </section>
  )
}
<script>
  import { animateNumbersAfterSolution } from "@/scripts/case-studies";

  animateNumbersAfterSolution();
</script>
