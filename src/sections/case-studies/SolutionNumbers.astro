---
// COMPONENTS //
import ClientIssues from "@/components/case-studies/ClientIssue.astro";

// DATA //
import { solutionNumbers } from "@/data/case-studies/1";
---

<section>
  <div
    class="container m-auto flex flex-col gap-9 px-6 py-16 md:gap-11 md:py-24 lg:gap-12 lg:py-28"
  >
    <p class="text-center text-2xl leading-tight md:text-3xl lg:text-4xl">
      Limitations That Guided The Process
    </p>

    <div class="flex flex-col gap-5">
      <!-- Iterate through Data -->
      {
        solutionNumbers.map((solutionNumberItem) => (
          <ClientIssues
            title={solutionNumberItem.title}
            description={solutionNumberItem.description}
            issue={solutionNumberItem.issue}
            stat={solutionNumberItem.stat}
          />
        ))
      }
    </div>
  </div>
</section>
