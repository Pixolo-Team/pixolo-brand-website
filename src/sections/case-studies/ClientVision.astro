---
// COMPONENTS //
import Image from "astro/components/Image.astro";
import ClientVision from "@/components/case-studies/ClientVision.astro";

// IMAGES //
import ClientImage from "@/data/case-studies/1/client-fcbarcelona-club.jpg";

// DATA //
import { clientVisions } from "@/data/case-studies/1";
---

<section>
  <!-- Container -->
  <div class="flex flex-col gap-7 px-6 py-14 md:gap-12 lg:gap-16">
    <!-- Page Title -->
    <p class="text-center text-3xl lg:text-4xl">The Client's Vision</p>
    <div class="flex flex-col gap-10 md:gap-12 lg:flex-row lg:items-center lg:gap-14">
      <!-- Client Image -->
      <Image class="w-full rounded-3xl lg:rounded-[60px]" src={ClientImage} alt="barcelona club " />

      <!-- Client Vision Component -->
      <div class="flex w-full flex-col items-center gap-9 lg:gap-10">
        <!-- Iterating through Data -->
        {
          clientVisions.map((clientVisionItem, index) => (
            <ClientVision
              title={clientVisionItem.title}
              description={clientVisionItem.description}
              index={String(index + 1).padStart(2, "0")}
            />
          ))
        }
      </div>
    </div>
  </div>
</section>
