---
// COMPONENTS //
import Image from "astro/components/Image.astro";
import ClientVisionItem from "@/components/case-studies/ClientVisionItem.astro";

interface props {
  clientVisionSectionMainImage: string;
  clientVisionSectionImageAlt: string;
  clientVisions: {
    title: string;
    description: string;
  }[];
}
const { clientVisionSectionMainImage, clientVisionSectionImageAlt, clientVisions } = Astro.props;
---

{
  clientVisionSectionMainImage && clientVisions.length > 0 && (
    // Clients Vision Section
    <section>
      {/* Container  */}
      <div class="container mx-auto flex flex-col gap-7 px-6 py-14 md:gap-12 lg:gap-16 lg:py-24">
        {/* Page Title */}
        <p class="text-center text-3xl lg:text-4xl">The Client's Vision</p>

        {/* Content Part */}
        <div class="flex flex-col gap-10 md:gap-12 lg:flex-row lg:items-center lg:gap-14">
          {/* Client Image */}
          {clientVisionSectionMainImage && (
            <Image
              src={`${clientVisionSectionMainImage}`}
              alt={clientVisionSectionImageAlt}
              class="w-full rounded-3xl md:rounded-4xl lg:w-auto lg:max-w-[50%]"
              width={700}
              height={700}
              referrerpolicy="no-referrer"
            />
          )}

          {clientVisions.length > 0 && (
            // Client Vision Component
            <div class="flex w-full flex-col items-center gap-9 lg:gap-10">
              {/* Iterating through Data  */}
              {clientVisions?.map((goalItem: any, goalItemIndex: number) => (
                <ClientVisionItem
                  title={goalItem.title}
                  description={goalItem.description}
                  index={String(goalItemIndex + 1).padStart(2, "0")}
                />
              ))}
            </div>
          )}
        </div>
      </div>
    </section>
  )
}
