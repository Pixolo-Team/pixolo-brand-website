---
// COMPONENTS //
import ToolUsed from "@/components/case-studies/ToolUsed.astro";

// DATA //
import { toolsUsed } from "@/data/case-studies/1";
---

<section>
  <div class="container m-auto flex flex-col gap-10 px-6 py-16 md:gap-4 lg:gap-16">
    <!-- Title -->
    <p class="text-center text-2xl capitalize md:text-3xl lg:text-4xl">
      The project relied on key tools to deliver effective results
    </p>
    <!-- Iterating through Data -->
    <div
      id="tools-used-wrapper"
      class="tool-item flex flex-col gap-4 md:gap-9 lg:grid lg:grid-cols-2"
    >
      {
        toolsUsed.map((toolUsedItem) => (
          <ToolUsed
            toolIcon={toolUsedItem.icon}
            toolTitle={toolUsedItem.title}
            toolDescription={toolUsedItem.description}
          />
        ))
      }
    </div>
  </div>
</section>

<script>
  import { animateToolsUsed } from "@/scripts/case-studies";

  animateToolsUsed();
</script>
