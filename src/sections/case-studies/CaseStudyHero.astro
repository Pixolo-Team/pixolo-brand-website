---
import { Image } from "astro:assets";
---

<div class="relative w-full overflow-hidden bg-n-50">
  <div class="container mx-auto flex flex-col items-center justify-start gap-8 px-6 py-14 md:gap-14 md:py-16 lg:gap-16 lg:py-24">
    <!-- Header Pill -->
    <div class="flex flex-col items-center justify-start gap-6 md:gap-6 lg:gap-7">
      <div
        data-usedin="Responsive"
        class="inline-flex items-center justify-center gap-2.5 rounded-3xl pl-1.5 pr-4 py-1.5 outline outline-1 outline-offset-[-1px] outline-n-950 md:gap-3 md:rounded-3xl lg:gap-4 lg:rounded-[32px] lg:pr-5"
      >
        <div class="flex items-center justify-center gap-2.5 rounded-3xl bg-blue-500 p-2">
          <div data-icon="Package" class="relative overflow-hidden w-3 h-3 md:w-4 md:h-4 lg:w-6 lg:h-6">
             <!-- Icon content: The snippet used a div. I'll keep it or assume it's a placeholder. -->
             <div class="absolute bg-n-950 w-2.5 h-2.5 left-[0.60px] top-[0.59px] md:w-3.5 md:h-3.5 md:left-[0.80px] md:top-[0.79px] lg:w-5 lg:h-5 lg:left-[1.20px] lg:top-[1.18px]"></div>
          </div>
        </div>
        <div class="text-center text-xs font-medium text-n-900 md:text-base lg:text-lg">
          UX Case Study
        </div>
      </div>

      <!-- Main Heading Content -->
      <div class="flex flex-col items-center justify-start gap-4 md:gap-4 lg:gap-5">
        <div class="inline-flex items-center justify-center gap-5 md:gap-7 lg:gap-8">
            <Image
            src="https://placehold.co/56x57"
            alt="FC Barcelona Logo"
            width={56}
            height={57}
            class="w-9 h-9 md:w-12 md:h-12 lg:w-14 lg:h-14"
          />
          <div class="text-start font-medium text-n-950 text-3xl leading-9 md:text-5xl md:leading-[60px] lg:text-6xl lg:leading-[75px]">
            FC Barcelona
          </div>
        </div>
        <div class="text-center font-normal text-n-950 text-base leading-5 md:text-2xl md:leading-8 lg:px-56 lg:text-3xl lg:leading-9">
          A full digital overhaul that unified experience across 3 continents. A full digital overhaul that unified experience across 3 continents.
        </div>
      </div>
    </div>

    <!-- Main Image -->
    <Image
      src="https://placehold.co/1536x616"
      alt="Case Study Showcase"
      width={1536}
      height={616}
      class="w-full flex-1 rounded-3xl object-cover md:h-80 md:rounded-[32px] lg:h-[616px] lg:rounded-[60px]"
    />
  </div>

  <!-- Visit Website Button (Placed outside container in snippets, but aligned? 
       In desktop snippet, it was below content. I'll put it below the container or inside?
       Snippet: Desktop outer wrapper > [ContentWrapper] > [Button].
       I will execute that logic. I'll place it inside the main Flex col to match vertical flow.
    -->
  <div class="flex flex-col items-center justify-center pb-14 md:pb-16 lg:pb-24">
      <div class="inline-flex items-center justify-center rounded-3xl bg-n-50 p-2.5">
        <div class="text-center text-base font-normal leading-5 text-n-950">
          Visit Website
        </div>
      </div>
      <!-- Small arrow icon at bottom -->
      <Image
        src="https://placehold.co/20x30"
        alt="Arrow"
        width={20}
        height={30}
        class="w-5 h-7 mt-2" 
      />
  </div>
</div>
