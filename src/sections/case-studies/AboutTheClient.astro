---
// COMPONENTS //
import ToolBadge from "@/components/ToolBadge.astro";
import { Image } from "astro:assets";

import ClientImage1 from "@/assets/images/case-study-consumption/client-barcelona-logo.png";
import ClientImage2 from "@/assets/images/case-study-consumption/client-barcelona-app.png";
import ClientImage3 from "@/assets/images/case-study-consumption/client-barcelona-player.png";
---

<section>
  <div
    class="text-n-950 container m-auto flex flex-col gap-8 px-6 py-20 leading-tight md:gap-14 md:py-20 lg:gap-16 lg:px-16 lg:py-28"
  >
    <!-- Toolbadge & Page Title -->
    <div class="flex flex-col items-center gap-4 lg:gap-5">
      <!-- Toolbadge -->
      <ToolBadge icon="package" text="Our Clients at a Glance" />
      <!-- Page Title -->
      <h1 class="text-center text-3xl font-medium md:text-5xl lg:text-6xl">
        Our Client at a Glance
      </h1>
    </div>

    <!-- Content Part -->
    <div class="flex flex-col gap-7 md:gap-12">
      <!-- Top Content : Client Title & Description -->
      <div class="lg:gap- flex flex-col gap-4 lg:flex-row">
        <!-- Title: Client Name -->
        <h2 class="text-2xl font-medium md:text-4xl lg:w-[30%]">Football Club Barcelona</h2>
        <!-- Work Description -->
        <p class="text-n-800 text-sm md:text-xl lg:flex-1">
          An app centred around providing users with a complete experience of Conscient Football
          tournaments which includes the fixtures, results, groups and an activity room. Users can
          post photos, upload status and use for downloading images and videos of various matches.
        </p>
      </div>
      <!-- Bottom Content-->
      <div class="flex flex-col gap-4 lg:flex-row">
        <!-- Title -->
        <h2 class="text-2xl font-medium md:text-4xl lg:w-[30%]">Brand Background</h2>
        <p class="text-n-800 text-sm md:text-xl lg:flex-1">
          The Barcelona Football Academy delivers elite football training inspired by top European
          methodologies. Designed for young players worldwide, the academy focuses on skill
          development, discipline, and long-term growth across all levels.
        </p>
      </div>
    </div>

    <!-- Images Section -->
    <div class="flex flex-col gap-4 lg:flex-row lg:gap-5">
      <!-- Top Image -->
      <Image
        class="rounded-3xl md:rounded-4xl lg:w-[60%] lg:rounded-[60px]"
        width={930}
        height={482}
        src={ClientImage1}
        alt="decorative illustration"
      />
      <!-- Bottom Images -->
      <div class="flex w-full gap-4 lg:gap-5">
        <Image
          class="flex-1 rounded-3xl md:rounded-4xl lg:rounded-[60px]"
          width={100}
          height={200}
          src={ClientImage2}
          alt="decorative illustration"
        />
        <Image
          class="flex-1 rounded-3xl md:rounded-4xl lg:rounded-[60px]"
          width={100}
          height={200}
          src={ClientImage3}
          alt="decorative illustration"
        />
      </div>
    </div>
  </div>
</section>
