---
// COMPONENTS //
import { Image } from "astro:assets";
import SectionHeader from "@/components/ui/SectionHeader.astro";

// DATA //
import { aboutClient } from "@/data/case-studies/1";
---

<section>
  <div
    class="text-n-950 container m-auto flex flex-col gap-8 px-6 py-20 leading-tight md:gap-14 md:py-20 lg:gap-16 lg:px-16 lg:py-28"
  >
    <!-- Toolbadge & Page Title -->
    <SectionHeader
      sectionTitle="Our Client at a Glance"
      badgeIcon="package"
      badgeText="Our Client at a Glance"
    />

    <!-- Content Part -->
    <div class="flex flex-col gap-7 md:gap-12">
      <!-- Iterating About the client Data -->
      {
        aboutClient.aboutPointers.map((aboutPointersItem) => (
          <div class="flex flex-col gap-4 lg:flex-row">
            {/* Title */}
            <h2 class="text-2xl font-medium md:text-4xl lg:w-[30%]">{aboutPointersItem.title}</h2>

            {/* Work Description */}
            <p class="text-n-800 text-sm md:text-xl lg:flex-1">{aboutPointersItem.description}</p>
          </div>
        ))
      }
    </div>

    <!-- Images Section -->
    <div class="flex flex-col gap-4 lg:flex-row lg:gap-5">
      <!-- Top Image -->
      <Image
        class="rounded-3xl md:rounded-4xl lg:w-[60%] lg:rounded-[60px]"
        width={930}
        height={482}
        src={aboutClient.aboutImages.mainImage}
        alt="Pixolo Client"
      />
      <!-- Bottom Images -->
      <div class="flex w-full gap-4 lg:gap-5">
        <Image
          class="flex-1 rounded-3xl md:rounded-4xl lg:rounded-[60px]"
          width={100}
          height={200}
          src={aboutClient.aboutImages.otherImages[0]}
          alt="Pixolo Client"
        />
        <Image
          class="flex-1 rounded-3xl md:rounded-4xl lg:rounded-[60px]"
          width={100}
          height={200}
          src={aboutClient.aboutImages.otherImages[1]}
          alt="Pixolo Client"
        />
      </div>
    </div>
  </div>
</section>
