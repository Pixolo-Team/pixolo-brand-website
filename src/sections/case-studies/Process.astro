---
// COMPONENTS //
import SectionHeader from "@/components/SectionHeader.astro";
import ClientProcessTimeline from "@/components/case-studies/ClientProcessTimeline.astro";

// DATA //
import { processSteps } from "@/data/case-studies/1";
---

<!-- Our Process Section -->
<section>
  <div class="container m-auto flex flex-col gap-12 px-6 py-24">
    <!-- Section Header -->
    <SectionHeader
      sectionTitle="Creating Human-Centered Experiences"
      badgeIcon="package"
      badgeText="Crafting The Journey"
    />

    <!-- Main Content -->
    <div class="relative flex flex-col items-center gap-6">
      <p class="text-n-800 text-center text-lg md:text-xl">Our Process</p>

      <!-- Timeline positioned for small screens -->
      <div class="relative w-full">
        <ClientProcessTimeline />

        <!-- Process Steps -->
        <div id="process-steps-container" class="flex flex-col gap-32 md:gap-40 lg:gap-60">
          {
            processSteps.map((processStepItem, processStepIndex) => (
              <div class="process-step relative flex items-start gap-8 md:gap-12">
                {/* Dots */}
                <div class="absolute top-0 left-5 md:left-1/2 md:-translate-x-1/2">
                  <div class="step-circle bg-n-950 -ml-2.5 flex size-5 items-center justify-center rounded-full transition-colors duration-500" />
                </div>

                {/* Index */}
                <div class="flex items-start gap-4 pl-12 md:w-1/2 md:justify-end md:pr-12 md:pl-0">
                  {/* Step Number */}
                  <div class="step-number text-n-950 flex shrink-0 items-center text-2xl font-semibold transition-colors duration-500 md:text-3xl">
                    {processStepIndex + 1}
                  </div>

                  {/* Title */}
                  <div class="flex flex-col gap-2">
                    <p class="step-title text-n-950 text-xl font-semibold transition-colors duration-500 md:text-right md:text-2xl">
                      {processStepItem.title}
                    </p>
                  </div>
                </div>

                {/* Description */}
                <div class="hidden md:block md:w-1/2 md:pl-12">
                  <p class="step-description text-n-500 transition-colors duration-500">
                    {processStepItem.description}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  window.addEventListener("load", () => {
    const processSteps = document.querySelectorAll(".process-step");
    const container = document.getElementById("process-steps-container");
    const outerLine = document.getElementById("outer-line");

    // Function to calculate and update timeline height
    const updateTimelineHeight = () => {
      if (!container || !outerLine || processSteps.length === 0) return;

      const firstStep = processSteps[0];
      const lastStep = processSteps[processSteps.length - 1];

      const firstStepTop = firstStep.getBoundingClientRect().top;
      const lastStepTop = lastStep.getBoundingClientRect().top;

      // Calculate the distance between first and last step
      const totalHeight = lastStepTop - firstStepTop;

      // Update the timeline height
      outerLine.style.setProperty("--timeline-height", `${totalHeight}px`);
    };

    // Update timeline height on load and resize
    updateTimelineHeight();
    window.addEventListener("resize", updateTimelineHeight);

    // Color transition logic
    const updateStepColors = () => {
      const triggerPositionTop = window.innerHeight / 4;

      processSteps.forEach((step, index) => {
        const stepRect = step.getBoundingClientRect();
        const stepTop = stepRect.top;

        // First step is always active, others activate when they pass trigger point
        const isActive = index === 0 || stepTop <= triggerPositionTop;

        const circle = step.querySelector(".step-circle");
        const stepNumber = step.querySelector(".step-number");
        const title = step.querySelector(".step-title");
        const descriptions = step.querySelectorAll(".step-description");

        if (isActive) {
          // Change to active colors
          circle.classList.remove("bg-n-500");
          circle.classList.add("bg-n-950");

          stepNumber.classList.remove("text-n-500");
          stepNumber.classList.add("text-n-950");

          title.classList.remove("text-n-500");
          title.classList.add("text-n-950");

          descriptions.forEach((desc) => {
            desc.classList.remove("text-n-500");
            desc.classList.add("text-n-700");
          });
        } else {
          // Reset to inactive colors
          circle?.classList.remove("bg-n-950");
          circle?.classList.add("bg-n-500");

          stepNumber?.classList.remove("text-n-950");
          stepNumber?.classList.add("text-n-500");

          title?.classList.remove("text-n-950");
          title?.classList.add("text-n-500");

          descriptions.forEach((desc) => {
            desc.classList.remove("text-n-700");
            desc.classList.add("text-n-500");
          });
        }
      });
    };

    // Initial calculation
    updateStepColors();

    // Update on scroll
    window.addEventListener("scroll", updateStepColors);
  });
</script>
