---
// COMPONENTS //
import SectionHeader from "@/components/ui/SectionHeader.astro";

// DATA //
import { processSteps } from "@/data/case-studies/case-study-consumption";
---

<!-- Our Process Section -->
<section>
  <div class="container mx-auto flex flex-col gap-12 px-6 py-24">
    <!-- Section Header -->
    <SectionHeader
      sectionTitle="Creating Human-Centered Experiences"
      badgeIcon="package"
      badgeText="Crafting The Journey"
    />

    <!-- Main Content -->
    <div class="relative flex flex-col items-center gap-6">
      <p class="text-n-800 text-center text-lg md:text-xl">Our Process</p>

      <!-- Timeline  -->
      <div class="relative w-full">
        {/* Process Steps */}
        <div
          id="process-steps-container"
          class="process-scroll-line relative flex flex-col gap-32 md:gap-40 lg:gap-60"
        >
          {
            processSteps.map((processStepItem, processStepIndex) => (
              <div class="process-step relative">
                {/* Step Dots - positioned at the timeline */}
                <div class="absolute top-1/2 left-5 z-10 -translate-y-1/2 md:left-1/2 md:-translate-x-1/2">
                  <div class="step-circle -ml-2.5 flex size-5 items-center justify-center rounded-full transition-colors duration-500 md:ml-0 lg:size-7" />
                </div>

                {/* Mobile Layout (sm): Number first, then Title */}
                <div class="flex gap-2 pl-12 md:hidden">
                  {/* Step Number */}
                  <div class="step-number text-n-500 flex items-center text-[28px] font-semibold transition-colors duration-500">
                    {processStepIndex + 1}
                  </div>

                  {/* Title */}
                  <p class="step-title text-n-500 text-[28px] font-semibold transition-colors duration-500">
                    {processStepItem.title}
                  </p>
                </div>

                {/* Desktop Layout (md/lg): Title, Number [Timeline] Description */}
                <div class="hidden md:flex md:items-center md:gap-12 lg:gap-20">
                  {/* Left side: Title and Number */}
                  <div class="flex w-1/2 items-center justify-end gap-4">
                    {/* Title */}
                    <p class="step-title text-n-500 text-right text-4xl font-semibold transition-colors duration-500 lg:text-[60px]">
                      {processStepItem.title}
                    </p>

                    {/* Step Number */}
                    <div class="step-number text-n-500 flex shrink-0 items-center text-[40px] transition-colors duration-500 lg:text-8xl">
                      {processStepIndex + 1}
                    </div>
                  </div>

                  {/* Right side: Description */}
                  <div class="w-1/2 pl-12">
                    <p class="step-description text-n-500 transition-colors duration-500 md:text-lg lg:text-2xl">
                      {processStepItem.description}
                    </p>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .process-scroll-line::before,
  .process-scroll-line::after {
    content: "";
    position: absolute;
    top: 0;
    width: 4px;
    transform: translateX(-50%);
    border-radius: 999px;
    left: 20px;
  }

  .process-scroll-line::before {
    height: var(--line-height, 0px);
    top: var(--line-top, 0px);
    background-color: var(--color-n-500);
    z-index: 0;
  }

  .process-scroll-line::after {
    height: var(--fill-height, 0%);
    top: var(--line-top, 0px);
    background-color: var(--color-n-950);
    z-index: 0;
    transition: height 150ms linear;
  }

  @media (min-width: 768px) {
    .process-scroll-line::before,
    .process-scroll-line::after {
      left: 50%;
    }
  }
</style>

<script>
  import { animateProcessStepScroll } from "@/scripts/case-studies";

  window.addEventListener("load", () => {
    animateProcessStepScroll();
  });
</script>
