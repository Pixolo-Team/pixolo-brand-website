---
// COMPONENTS //
import SectionHeader from "@/components/SectionHeader.astro";
import ClientProcessTimeline from "@/components/case-studies/ClientProcessTimeline.astro";

// DATA //
import { processSteps } from "@/data/case-studies/1";
---

<!-- Our Process Section -->
<section>
  <div class="container m-auto flex flex-col gap-12 px-6 py-24">
    <!-- Section Header -->
    <SectionHeader
      sectionTitle="Creating Human-Centered Experiences"
      badgeIcon="package"
      badgeText="Crafting The Journey"
    />

    <!-- Main Content -->
    <div class="relative flex flex-col items-center gap-6">
      <p class="text-n-800 text-center text-lg md:text-xl">Our Process</p>

      <!-- Timeline  -->
      <div class="relative w-full">
        <ClientProcessTimeline />

        <!-- Process Steps -->
        <div id="process-steps-container" class="flex flex-col gap-32 md:gap-40 lg:gap-60">
          {
            processSteps.map((processStepItem, processStepIndex) => (
              <div class="process-step relative flex gap-8 md:items-center md:gap-12">
                {/* Step Dots */}
                <div class="absolute top-2 left-5 md:top-auto md:left-1/2 md:-translate-x-1/2 md:pl-3">
                  <div class="step-circle bg-n-500 -ml-2.5 flex size-5 items-center justify-center rounded-full transition-colors duration-50 lg:size-7" />
                </div>

                {/* Index */}
                <div class="flex items-start gap-4 pl-12 md:w-1/2 md:flex-row-reverse md:pl-0">
                  {/* Step Number */}
                  <div class="step-number text-n-500 flex shrink-0 items-center text-[28px] font-semibold transition-colors duration-500 md:text-3xl md:text-[40px] lg:text-8xl">
                    {processStepIndex + 1}
                  </div>

                  {/* Title */}
                  <div class="flex flex-col gap-2">
                    <p class="step-title text-n-500 text-[28px] font-semibold transition-colors duration-500 md:text-right md:text-4xl lg:text-[60px]">
                      {processStepItem.title}
                    </p>
                  </div>
                </div>

                {/* Description */}
                <div class="hidden md:block md:w-1/2 md:pl-12">
                  <p class="step-description text-n-500 transition-colors duration-50 md:text-lg lg:text-2xl">
                    {processStepItem.description}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  window.addEventListener("load", () => {
    const processSteps = document.querySelectorAll(".process-step");
    const container = document.getElementById("process-steps-container");
    const outerLine = document.getElementById("outer-line");
    const internalLine = document.getElementById("internal-line");

    if (!container || !outerLine || !internalLine || processSteps.length === 0) return;

    // Function to calculate and update timeline height
    const updateTimelineHeight = () => {
      const firstStep = processSteps[0];
      const lastStep = processSteps[processSteps.length - 1];

      const firstStepTop = firstStep.getBoundingClientRect().top;
      const lastStepTop = lastStep.getBoundingClientRect().top;

      const totalHeight = lastStepTop - firstStepTop;
      outerLine.style.setProperty("--timeline-height", `${totalHeight}px`);
    };

    // Update timeline height on load and resize
    updateTimelineHeight();
    window.addEventListener("resize", updateTimelineHeight);

    // Color transition logic based on circle position
    const updateStepColors = () => {
      const triggerPositionTop = window.innerHeight / 4;
      const outerLineRect = outerLine.getBoundingClientRect();
      const outerLineTop = outerLineRect.top;
      const outerLineHeight = outerLineRect.height;

      // Position of the circle (at the trigger point)
      const circlePosition = triggerPositionTop;

      processSteps.forEach((step) => {
        const stepCircle = step.querySelector(".step-circle");

        // Get the step's circle position
        const stepCircleRect = stepCircle.getBoundingClientRect();
        const stepCircleTop = stepCircleRect.top;

        // Check if the moving circle has reached this step's circle
        const isActive = circlePosition >= stepCircleTop;

        const stepNumber = step.querySelector(".step-number");
        const title = step.querySelector(".step-title");
        const descriptions = step.querySelectorAll(".step-description");

        if (isActive) {
          stepCircle?.classList.remove("bg-n-500");
          stepCircle?.classList.add("bg-n-950");
          stepNumber?.classList.remove("text-n-500");
          stepNumber?.classList.add("text-n-950");
          title?.classList.remove("text-n-500");
          title?.classList.add("text-n-950");
          descriptions.forEach((desc) => {
            desc?.classList.remove("text-n-500");
            desc?.classList.add("text-n-700");
          });
        } else {
          stepCircle?.classList.remove("bg-n-950");
          stepCircle?.classList.add("bg-n-500");
          stepNumber?.classList.remove("text-n-950");
          stepNumber?.classList.add("text-n-500");
          title?.classList.remove("text-n-950");
          title?.classList.add("text-n-500");
          descriptions.forEach((desc) => {
            desc?.classList.remove("text-n-700");
            desc?.classList.add("text-n-500");
          });
        }
      });
    };

    // Initial calculation
    updateStepColors();

    // Update on scroll
    window.addEventListener("scroll", updateStepColors);
  });
</script>
