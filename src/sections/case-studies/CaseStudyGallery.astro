---
// COMPONENTS //
import SectionHeader from "@/components/SectionHeader.astro";
import Image from "astro/components/Image.astro";
import NavigationArrows from "@/components/NavigationArrows.astro";

// DATA //
import { clientGallery } from "@/data/case-studies/1";

const { icon = "right-arrow" } = Astro.props;
---

<section>
  <div
    class="container mx-auto flex flex-col gap-7 px-6 py-16 md:gap-12 md:py-24 lg:gap-16 lg:py-28"
  >
    <SectionHeader
      badgeIcon={clientGallery.badgeIcon}
      badgeText={clientGallery.badgeText}
      sectionTitle={clientGallery.sectionTitle}
    />

    <!-- Image Slideshow -->
    <div class="case-study-gallery-slider relative flex flex-col gap-3">
      <div
        id="embla-cs-gallery-slider"
        class="overflow-hidden rounded-2xl md:rounded-4xl lg:rounded-[60px]"
      >
        <!-- Embla Slide Container -->
        <div class="flex">
          <!-- Iterating through Data & Embla Slides-->
          {
            clientGallery.images.map((clientGalleryImageItem) => (
              <div class="flex-none basis-full">
                <div class="w-full rounded-3xl md:max-h-[350px] md:rounded-4xl lg:max-h-[665px] lg:rounded-[60px]">
                  <Image
                    width={1536}
                    height={665}
                    src={clientGalleryImageItem.imagePath}
                    alt={clientGalleryImageItem.alt}
                  />
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <NavigationArrows icon={icon} />
    </div>
  </div>
</section>

<!-- Button Logic -->
<script src="https://unpkg.com/embla-carousel/embla-carousel.umd.js"></script>
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const viewport = document.querySelector("#embla-cs-gallery-slider");

    if (!viewport) {
      return;
    }

    const caseStudyGallerySlider = EmblaCarousel(viewport, { loop: true });
    document.querySelector(".prev-btn").onclick = () => caseStudyGallerySlider.scrollPrev();
    document.querySelector(".next-btn").onclick = () => caseStudyGallerySlider.scrollNext();
  });
</script>


