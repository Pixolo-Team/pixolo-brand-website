---
// COMPONENTS //
import ToolBadge from "@/components/ui/ToolBadge.astro";
import { Image } from "astro:assets";

interface props {
  badgeTitle: string;
  title: string;
  description: string;
  thumbnail: string;
  websiteLink: string;
  name: string;
}

const {
  badgeTitle = "",
  title = "",
  description = "",
  thumbnail = "",
  websiteLink = "",
  name,
} = Astro.props as props;
---

<!-- Case Study Consumption Hero Section -->
<section id="case-study-consumption-hero">
  <!-- Container -->
  <div
    class="hero-padding-top container mx-auto flex flex-col items-center justify-start gap-8 px-6 pb-18 md:gap-14 md:pt-20 md:pb-16 lg:gap-16 lg:pb-24"
  >
    <div class="flex flex-col items-center justify-start gap-6 md:gap-6 lg:gap-7">
      {
        badgeTitle !== "" && (
          // ToolBadge
          <div class="tool-badge">
            <ToolBadge icon={"building"} text={badgeTitle} />
          </div>
        )
      }

      {
        title !== "" && (
          // Main Heading Content
          <div class="header-text flex flex-col items-center justify-center gap-4 md:gap-4 lg:gap-5">
            <div class="flex items-center justify-center gap-5 md:gap-7 lg:gap-8">
              {/* Client Name */}
              <p class="text-n-950 text-center text-3xl leading-tight font-medium md:text-5xl lg:text-6xl">
                {title}
              </p>
            </div>

            {/* Description */}
            {description !== "" && (
              <p class="text-n-950 text-center leading-tight md:text-2xl lg:text-3xl xl:w-[80%]">
                {description}
              </p>
            )}
          </div>
        )
      }
    </div>

    {
      thumbnail && (
        // Main Image Container
        <div class="relative w-full" id="main-image-container">
          <div class="hero-thumbnail h-[148px] overflow-hidden rounded-3xl md:h-[310px] md:rounded-4xl lg:h-[420px] lg:rounded-[60px] xl:h-[620px]">
            {websiteLink !== "" ? (
              // Clickable Thumbnail Image
              <a href={websiteLink} target="_blank" rel="noopener noreferrer">
                <Image
                  src={thumbnail}
                  alt={name}
                  width={1536}
                  height={616}
                  class="h-full w-full object-cover"
                  id="main-image"
                  referrerpolicy="no-referrer"
                />
              </a>
            ) : (
              <Image
                src={thumbnail}
                alt={name}
                width={1536}
                height={616}
                class="h-full w-full object-cover"
                id="main-image"
              />
            )}
          </div>

          {websiteLink !== "" && (
            // Visit Website show on Hover
            <div
              id="custom-cursor"
              class="bg-n-50 pointer-events-none absolute z-50 hidden -translate-x-1/2 items-center justify-center rounded-3xl p-2 md:p-2.5"
            >
              <a
                href={websiteLink}
                target="_blank"
                rel="noopener noreferrer"
                class="text-n-950 text-center text-xs leading-tight whitespace-nowrap md:text-sm lg:text-base"
              >
                Vist Website
              </a>
            </div>
          )}
        </div>
      )
    }
  </div>
</section>
<script>
  import { animateCaseStudyConsumptionHero, animateHeroImageLink } from "@/scripts/case-studies";

  animateCaseStudyConsumptionHero();
  animateHeroImageLink();
</script>
