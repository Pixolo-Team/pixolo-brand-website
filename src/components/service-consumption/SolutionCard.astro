---
// Interface props
interface props {
  number: string;
  title: string;
  description: string;
}

const { number, title, description } = Astro.props as props;
---

<!-- Solution Card Component -->
<div
  class="solution-card border-n-500 rounded-4xl flex flex-col gap-3.5 border px-4 pb-6 pt-4 md:gap-5 md:px-7 md:pb-9 md:pt-7 lg:gap-9 lg:px-8 lg:pb-16 lg:pt-8"
>
  <!-- Number -->
  <p
    class="solution-text text-n-950 text-4xl font-normal leading-tight tracking-[-4%] md:text-6xl lg:text-8xl"
  >
    {number}
  </p>
  <!-- Content Wrapper -->
  <div class="flex flex-col gap-2 md:gap-4 lg:gap-6">
    <!-- Title -->
    <p class="solution-text text-n-950 text-base font-normal leading-tight md:text-2xl lg:text-3xl">
      {title}
    </p>

    <!-- Description -->
    <p class="solution-text text-n-600 text-xs font-normal leading-tight md:text-base lg:text-xl">
      {description}
    </p>
  </div>
</div>

<style>
  /* Initial states */
  .solution-card {
    opacity: 0;
    transform: translateY(30px);
    will-change: transform, opacity;
  }

  .solution-text {
    opacity: 0;
    transform: translateX(-20px);
    will-change: transform, opacity;
  }
</style>
