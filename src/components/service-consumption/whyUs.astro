---
interface props {
  number: string;
  description: string;
}
const { number, description } = Astro.props as props;
---

<div class="flex w-full">
  <p
    class="text-n-700 self-baseline-last text-xl leading-normal font-normal tracking-[-0.02em] capitalize md:text-3xl"
  >
    {number}
  </p>
  <div class="flex w-full grow justify-end border-b md:py-3 md:pr-4 md:pl-8">
    <p class="text-n-950 text-right text-base leading-tight font-normal capitalize md:text-2xl">
      {description}
    </p>
  </div>
</div>
