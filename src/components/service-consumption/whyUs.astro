---
interface props {
  number: string;
  description: string;
}
const { number, description } = Astro.props as props;
---

<div class="flex w-full items-baseline-last lg:gap-2.5">
  <p
    class="text-n-700 flex-none text-xl leading-normal font-normal tracking-[-0.02em] capitalize md:text-3xl"
  >
    {number}
  </p>
  <div class="flex flex-1 grow justify-end border-b md:py-3 md:pr-4 md:pl-8">
    <p
      class="text-n-950 max-w-75 text-right text-base leading-tight font-normal capitalize md:max-w-184 md:text-2xl lg:max-w-174.5"
    >
      {description}
    </p>
  </div>
</div>
