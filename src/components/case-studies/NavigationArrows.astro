---
// COMPONENTS //
import { Icon } from "astro-icon/components";

const { icon = "right-arrow" } = Astro.props;
---

<!-- ARROWS -->
<div class="flex justify-end gap-2 md:gap-4 lg:gap-5">
  <!-- Previous Button -->
  <button
    type="button"
    aria-label="Previous"
    class="prev-btn arrowbtn-fill bg-n-50 flex size-9 items-center justify-center rounded-full hover:cursor-pointer md:size-10 lg:size-16"
  >
    <Icon name={icon} class="text-n-950 size-3 rotate-180 md:size-4 lg:size-6" />
  </button>

  <!-- Next Button -->
  <button
    type="button"
    aria-label="Next"
    class="next-btn arrowbtn-fill bg-n-50 flex size-9 items-center justify-center rounded-full hover:cursor-pointer md:size-10 lg:size-16"
  >
    <Icon name={icon} class="text-n-950 size-3 md:size-4 lg:size-6" />
  </button>
</div>

<!-- Slider Arrows Hover Animation -->
<style>
  .arrowbtn-fill {
    position: relative;
    overflow: hidden;
    z-index: 20;
  }

  .arrowbtn-fill::before {
    content: "";
    position: absolute;
    inset: 0;
    height: 0%;
    background: var(--color-n-300);
    transition: height 0.5s ease-in-out;
    z-index: -1;
  }

  .arrowbtn-fill:hover::before {
    height: 100%;
  }
</style>
