---
interface Props {
  title: string;
  description: string;
  issue: string;
  stat: string;
}

const { title, description, issue, stat } = Astro.props;
---

<!-- Client Issue Component -->
<div
  class="bg-n-100 text-n-950 container m-auto flex flex-col items-center gap-1.5 rounded-3xl px-3 pt-3.5 pb-2.5 text-center text-sm leading-tight font-medium md:flex-row md:justify-between md:gap-5 md:rounded-[100px] md:p-2 md:text-base lg:gap-6 lg:text-xl"
>
  <!-- Issue Title -->

  <p
    class="md:border-n-600 leading-tight md:flex md:h-28 md:w-28 md:items-center md:justify-center md:rounded-full md:border md:px-8 md:py-12 lg:h-[147px] lg:w-[147px] lg:px-8 lg:py-12"
  >
    {title}
  </p>

  <div class="flex flex-col gap-3">
    <!-- Issue Description -->
    <p class="leading-tight font-normal">{description}</p>

    <!-- Stat Box -->
    <div
      class="bg-n-200 flex flex-col items-center gap-1 rounded-2xl px-9 py-2 leading-tight md:gap-2 md:rounded-[100px] md:px-11 md:py-6 lg:gap-2 lg:px-11 lg:py-7"
    >
      <p>{issue}</p>
      <p class="text-2xl leading-tight md:text-3xl lg:text-5xl">{stat}</p>
    </div>
  </div>
</div>
