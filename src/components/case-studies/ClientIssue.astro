---
interface Props {
  title: string;
  description: string;
  issue: string;
  stat: string;
}

const { title, description, issue, stat } = Astro.props;
---

<!-- Client Issue Component -->
<div
  class="sol-num bg-n-100 text-n-950 flex flex-col items-center gap-1.5 rounded-3xl px-3 pt-3.5 pb-2.5 text-center text-sm leading-tight font-medium md:flex-row md:justify-between md:gap-5 md:rounded-[100px] md:p-2 md:text-base lg:gap-6 lg:text-xl"
>
  <!-- Issue Title -->
  <div
    class="md:border-n-600 w-28 text-center md:flex md:items-center md:justify-center md:rounded-full md:border md:px-6 md:py-10 lg:w-[150px]"
  >
    <p class="lg:text-center lg:wrap-break-word">
      {title}
    </p>
  </div>

  <!-- Issue Description -->
  <p class="mb-1.5 font-normal md:mb-0">{description}</p>

  <!-- Stat Box -->
  <div
    class="bg-n-200 flex w-full flex-col items-center justify-center gap-1 rounded-2xl px-9 py-2 md:w-auto md:gap-2 md:rounded-full md:px-11 md:py-6 lg:gap-2 lg:px-11 lg:py-7"
  >
    <p>{issue}</p>
    <p class="text-2xl md:text-3xl md:whitespace-nowrap lg:text-5xl">{stat}</p>
  </div>
</div>
