---
// COMPONENTS //
import { Icon } from "astro-icon/components";
import Image from "astro/components/Image.astro";

interface Props {
  name: string;
  logo: string;
  thumbnail: string;
  image: string;
  description: string;
  href?: string;
}

const { name, logo, thumbnail, image, description, href = "" } = Astro.props as Props;
---

<!-- Product Item -->
<a
  href={href !== "" ? href : undefined}
  target="_blank"
  class="group border-n-950 relative flex w-full cursor-pointer flex-col gap-3 border-b-[0.4px] py-7 md:gap-3.5 md:border-b-[0.6px] lg:flex-row lg:justify-between lg:gap-12 lg:border-b-[0.8px]"
>
  <!-- Logo Container -->
  <div class="flex gap-2.5 lg:w-2/5">
    <Image
      src={`/images/products/${logo}`}
      alt={`${name} logo`}
      width={180}
      height={63}
      class="object-contain md:h-[88px] md:w-[250px]"
    />
  </div>

  <!-- Hover Image (Desktop only) -->
  <div
    class="pointer-events-none absolute top-30 left-[22%] z-50 hidden -translate-y-1/2 scale-95 opacity-0 transition-all duration-300 ease-out group-hover:scale-100 group-hover:opacity-100 lg:left-[27%] lg:block xl:left-[22%] 2xl:left-[22%]"
  >
    <Image
      src={`/images/products/${image}`}
      alt={`${name} preview`}
      width={200}
      height={280}
      class="h-auto w-40 rounded-[28px] object-cover shadow-2xl lg:w-[140px] xl:w-[220px] 2xl:w-[250px]"
    />
  </div>

  <!-- Product Image -->
  <Image
    src={`/images/products/${thumbnail}`}
    alt={`${name} thumbnail`}
    width={327}
    height={140}
    class="h-[140px] w-full rounded-[25px] object-cover md:h-[209px] lg:hidden"
  />

  <!-- Content -->
  <div class="flex w-full items-center justify-center gap-6 md:gap-16 lg:w-3/5 lg:gap-16">
    <!-- Description -->
    <p class="text-n-700 text-xs leading-normal font-normal md:text-base">
      {description}
    </p>

    <!-- Link for more information -->
    {
      href !== "" && (
        <div
          class="border-n-950 flex size-12 shrink-0 cursor-pointer items-center justify-center self-center rounded-full border from-(--blue-500) to-[#8B77F3] group-hover:border-none group-hover:bg-gradient-to-r md:size-20"
          aria-label="View more information"
        >
          <Icon name="external-link-icon" class="size-[18px] md:size-[30px]" />
        </div>
      )
    }
  </div>
</a>
