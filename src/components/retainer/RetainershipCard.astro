---
// Interface Props
interface props {
  number: string;
  title: string;
  description: string;
}

const { number, title, description } = Astro.props as props;
---

<div
  class="retainership-card group bg-n-100 flex min-h-[311px] w-full flex-col justify-between gap-4 rounded-4xl from-[#4254D4] to-[#8B77F3] py-14 pr-14 pl-6 hover:bg-gradient-to-br md:min-h-[380px] lg:min-h-[428px]"
>
  <!-- Header -->
  <div class="flex flex-col gap-2">
    <!-- Number -->
    <p class="text-n-950 text-3xl leading-tight font-medium tracking-[-0.07em] md:text-4xl">
      {number}
    </p>

    <!-- Title -->
    <p class="text-n-950 text-3xl leading-tight font-medium md:text-4xl">
      {title}
    </p>
  </div>

  <!-- Description -->
  <p class="text-n-800 text-base leading-normal font-normal group-hover:font-medium">
    {description}
  </p>
</div>
<style>
  .retainership-card {
    transform: translateX(40px);
    opacity: 0;
    will-change: transform, opacity;
  }
</style>
