---
interface Props {
  title: string;
  image: string;
  tags: string[];
}

const { title, image, tags } = Astro.props;
---

<div class="flex flex-col items-start gap-3.5 md:gap-10 lg:gap-5">
  <div class="h-[303px] md:h-[450px] w-auto overflow-hidden rounded-4xl">
    <img src={image} alt={title} class="h-full w-full" />
  </div>

  <div class="flex flex-col gap-2.5 md:gap-4 lg:gap-3.5">
    <p class="text-xl font-normal md:text-4xl lg:text-5xl">{title}</p>

    <div class="flex flex-wrap gap-2.5 text-sm md:gap-4 md:text-base lg:gap-2.5 lg:text-sm">
      {
        tags.map((tag) => (
          <p class="border-n-800 self-center rounded-full border px-3 py-1.5 leading-tight tracking-normal md:px-4 md:py-2.5">
            {tag}
          </p>
        ))
      }
    </div>
  </div>
</div>
