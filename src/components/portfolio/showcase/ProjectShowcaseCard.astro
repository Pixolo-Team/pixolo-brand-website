---
// COMPONENTS //
import { Image } from "astro:assets";
import RoundedButton from "@/components/ui/RoundedButton.astro";
import Tag from "@/components/portfolio/showcase/Tag.astro";
import { Icon } from "astro-icon/components";

// Define Props //
interface Props {
  id?: string;
  name: string;
  image: string;
  title: string;
  subTitle: string;
  description: string;
  date?: string;
  tagItems: string[];
  buttonOneText: string;
  buttonTwoText: string;
  buttonOneClick?: string;
  buttonTwoClick?: string;
  platform?: string;
  buttonOneHref?: string;
  buttonTwoHref?: string;
  playStoreHref?: string;
  appStoreHref?: string;
}

const {
  id = "",
  name,
  image,
  title,
  subTitle,
  description,
  date = "",
  tagItems,
  buttonOneText,
  buttonTwoText,
  buttonOneClick = "",
  buttonTwoClick = "",
  platform = "web",
  buttonOneHref = "#",
  buttonTwoHref = "#",
  playStoreHref = "",
  appStoreHref = "",
} = Astro.props as Props;

const normalizedButtonOneHref = buttonOneHref.trim();
const normalizedButtonTwoHref = buttonTwoHref.trim();
const normalizedPlayStoreHref = (playStoreHref || buttonOneHref).trim();
const normalizedAppStoreHref = (appStoreHref || buttonTwoHref).trim();
const hasPrimaryButton = normalizedButtonOneHref !== "" && normalizedButtonOneHref !== "#";
const hasSecondaryButton = normalizedButtonTwoHref !== "" && normalizedButtonTwoHref !== "#";
const hasPlayStoreButton = normalizedPlayStoreHref !== "" && normalizedPlayStoreHref !== "#";
const hasAppStoreButton = normalizedAppStoreHref !== "" && normalizedAppStoreHref !== "#";
---

<!-- Project Card -->
<div
  id="portfolio-showcase-project-card"
  class=`flex flex-col group-data-[view=list]:md:flex-row gap-3.5 group-data-[view=list]:md:gap-7 group-data-[view=list]:lg:gap-10 group-data-[view=list]:xl:gap-12 group-data-[view=grid]:lg:gap-5`
>
  <!-- Project Card Image -->
  <div
    class=`project-card-image bg-n-100 w-full overflow-hidden rounded-3xl p-4 group-data-[view=list]:md:flex-1 group-data-[view=list]:md:h-auto md:p-5 lg:p-6`
  >
    <Image
      src={image}
      alt={name}
      width={327}
      height={238}
      class="h-full w-full rounded-2xl object-contain"
      loading="lazy"
    />
  </div>

  <!-- Content -->
  <div
    class="flex flex-1 flex-col justify-between gap-12 group-data-[view=grid]:px-1 group-data-[view=grid]:md:px-2 group-data-[view=grid]:lg:px-4"
  >
    <!-- Details Wrap -->
    <div
      class="flex flex-col gap-7 group-data-[view=grid]:gap-5 group-data-[view=grid]:md:gap-2 lg:gap-8 group-data-[view=grid]:lg:gap-6"
    >
      <!-- Header -->
      <div class="project-card-header flex flex-col gap-2 md:gap-3">
        <!-- Title -->
        <p class="text-n-950 text-2xl leading-tight font-normal md:text-3xl lg:text-4xl">
          {name}
        </p>

        <!-- Tags -->
        {
          tagItems.length > 0 && (
            <div class="flex flex-wrap gap-2 md:gap-2.5">
              {tagItems.map((tagItem) => {
                return tagItem !== "" && <Tag tagName={tagItem} />;
              })}
            </div>
          )
        }
      </div>

      <!-- About -->
      <div class="project-card-content flex flex-col gap-4 md:gap-6 lg:gap-7">
        <!-- SubTitle -->
        {
          title && (
            <p class="text-n-700 text-sm leading-tight font-medium md:text-base lg:text-lg">
              {title}
            </p>
          )
        }

        <!-- Description -->
        <p class="text-n-600 text-xs leading-tight font-normal md:text-sm lg:text-base">
          {subTitle}
        </p>

        {
          date !== "" && (
            // Date
            <p class="text-n-700 text-xs leading-tight font-normal md:text-sm">{date}</p>
          )
        }
      </div>
    </div>

    <!-- Buttons -->
    <div class="project-card-buttons flex flex-row gap-3.5 group-data-[view=grid]:gap-4 md:gap-4">
      {
        platform === "app" ? (
          <>
            {/* Play Store */}
            {hasPlayStoreButton && (
              <a
                target="_blank"
                href={normalizedPlayStoreHref}
                class="bg-n-950 hover:bg-n-500 flex size-11 cursor-pointer items-center justify-center rounded-full transition-all duration-300 md:size-12 lg:size-14"
              >
                <span class="flex items-center justify-center">
                  <Icon name="play-store" class="text-n-100 size-5" />
                </span>
              </a>
            )}

            {/* App Store */}
            {hasAppStoreButton && (
              <a
                target="_blank"
                href={normalizedAppStoreHref}
                class="bg-n-950 hover:bg-n-500 flex size-11 cursor-pointer items-center justify-center rounded-full transition-all duration-300 md:size-12 lg:size-14"
              >
                <Icon name="app-store" class="text-n-100 size-5" />
              </a>
            )}
          </>
        ) : (
          // Primary Button
          hasPrimaryButton && (
            <RoundedButton
              buttonText={buttonOneText}
              onClick={buttonOneClick}
              href={normalizedButtonOneHref}
              openInNewTab={true}
            />
          )
        )
      }

      <!-- Secondary Button -->
      {
        hasSecondaryButton && (
          <RoundedButton
            buttonText={buttonTwoText}
            onClick={buttonTwoClick}
            href={normalizedButtonTwoHref}
            variant="secondary"
          />
        )
      }
    </div>
  </div>
</div>
