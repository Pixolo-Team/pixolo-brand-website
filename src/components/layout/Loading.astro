<style>
  .icon-slot {
    position: relative;
  }

  @layer utilities {
    @keyframes orbit {
      to {
        transform: rotate(360deg);
      }
    }

    @keyframes marble {
      to {
        transform: rotate(-360deg);
      }
    }

    .animate-orbit {
      animation: orbit 2s linear infinite;
    }

    .animate-marble {
      animation: marble 6s linear infinite;
    }
  }

  #loading-screen.hide-text #loader-text {
    opacity: 0;
    transform: translateY(24px);
  }
</style>

<script>
  import { initLoader } from "@/scripts/loader";

  initLoader();
</script>
