---
// COMPONENTS //
import BrandLogo from "@/components/ui/BrandLogo.astro";
import MenuBar from "@/components/ui/MenuBar.astro";
import RoundedButton from "@/components/ui/RoundedButton.astro";
import MobileMenu from "@/components/layout/MobileMenu.astro";
import { Icon } from "astro-icon/components";

// DATA //
import { menuItems, mobileMenuItems } from "@/data/menu";
import ThemeToggle from "@/components/ui/ThemeToggle.astro";
---

<header
  class="relative z-20 dark:bg-linear-to-b dark:from-[#020617C4] dark:via-[#020617A1] dark:to-transparent"
>
  <div class="container mx-auto flex items-center justify-between p-6 lg:p-4">
    <!-- Brand logo Component -->
    <a href="/">
      <BrandLogo width={140} />
    </a>

    <!-- Menubar -->
    <div class="hidden lg:block">
      <MenuBar items={menuItems} />
    </div>

    <!-- Rounded Button component -->
    <div class="hidden items-center justify-center gap-4 lg:flex">
      <!-- Theme toggle Button -->
      <ThemeToggle id="header-theme-toggle" />

      <!-- Divider line -->
      <div class="bg-n-600 w-[1px] self-stretch"></div>

      <!-- Contact CTA Button -->
      <RoundedButton
        id="header-contact-cta"
        buttonText="Contact Us"
        onClick="window.location.href='/contact'"
      />
    </div>

    <div class="flex items-center justify-center gap-3 lg:hidden">
      <!-- Theme toggle Button -->
      <ThemeToggle id="mobile-theme-toggle" />

      <!-- Divider line -->
      <div class="bg-n-600 w-[1px] self-stretch"></div>

      <!-- Mobile Hamburger -->
      <Icon
        id="open-mobile-menu-button"
        aria-label="Open menu button"
        name="hamburger"
        class="text-n-950 block size-6 cursor-pointer lg:hidden"
      />
    </div>
  </div>
</header>

<!-- Mobile Menu -->
<MobileMenu menuItems={mobileMenuItems} />

<script>
  import { menuOpenCloseAnimation, animateMenu } from "@/scripts/menu";
  import { trackContactCTAClick, setupClickTracking } from "@/scripts/analytics";

  setupClickTracking("header-contact-cta", () => trackContactCTAClick("nav"));

  /** Menu open close animation  */
  menuOpenCloseAnimation();

  /** Menu background logo animation  */
  animateMenu();
</script>
