---
// COMPONENTS //
import BrandLogo from "@/components/ui/BrandLogo.astro";
import MenuBar from "@/components/ui/MenuBar.astro";
import RoundedButton from "@/components/ui/RoundedButton.astro";
import MobileMenu from "@/components/layout/MobileMenu.astro";
import { Icon } from "astro-icon/components";

// DATA //
import { menuItems } from "@/data/menu";
---

<header class="relative z-20 bg-linear-to-b from-[#020617C4] via-[#020617A1] to-transparent">
  <div class="container mx-auto flex items-center justify-between p-6 lg:p-4">
    <!-- Brand logo Component -->
    <a href="/">
      <BrandLogo width={140} />
    </a>

    <!-- Menubar -->
    <div class="hidden lg:block">
      <MenuBar items={menuItems} />
    </div>

    <!-- Rounded Button component -->
    <div class="hidden lg:block">
      <RoundedButton buttonText="Contact Us" onClick="window.location.href='/contact'" />
    </div>

    <!-- Mobile Hamburger -->
    <Icon
      id="open-mobile-menu-button"
      aria-label="Open menu button"
      name="hamburger"
      class="text-n-950 block size-6 cursor-pointer lg:hidden"
    />
  </div>
</header>

<!-- Mobile Menu -->
<MobileMenu menuItems={menuItems} />

<script>
  import { menuOpenCloseAnimation, animateMenu } from "@/scripts/menu";

  /** Menu open close animation  */
  menuOpenCloseAnimation();

  /** Menu background logo animation  */
  animateMenu();
</script>
