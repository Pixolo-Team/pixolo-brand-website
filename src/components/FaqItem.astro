---
import { Icon } from "astro-icon/components";

const { question, answer, isOpen, index } = Astro.props;
---

<div
  class="group text-n-700 flex cursor-pointer flex-col gap-3.5 border-t-[0.8px] border-b-[0.8px] px-2 py-8 md:py-12 lg:px-2.5 lg:py-14"
  data-faq-toggle={index}
>
  <div class="flex items-center justify-between">
    <div
      class="gap-3.5 px-2.5 pt-8 pb-4 text-base leading-tight transition-transform duration-300 md:text-2xl lg:text-3xl lg:group-hover:scale-105"
    >
      {question}
    </div>

    <Icon
      name="plus"
      id={`faq-icon-${index}`}
      class="w-5 cursor-pointer transition-transform duration-300 lg:group-hover:scale-105"
    />
  </div>

  <div
    id={`faq-answer-${index}`}
    class={`text-n-700 flex flex-col gap-2 pb-6 text-xs md:text-lg lg:text-xl ${!isOpen ? "hidden" : ""}`}
  >
    <div class="pr-5 pl-2.5">{answer}</div>
  </div>
</div>
