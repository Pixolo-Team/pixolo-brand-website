---
interface TabPropsData {
  text: string;
}

const { text } = Astro.props as TabPropsData;
---

<!-- Deliverables Tab -->
<div class="bg-n-100 w-full rounded-xl py-3 lg:max-w-119 lg:py-4">
  <p
    class="text-n-950 text-center text-base leading-tight font-normal tracking-[-0.02em] md:text-lg lg:text-2xl"
  >
    {text}
  </p>
</div>
