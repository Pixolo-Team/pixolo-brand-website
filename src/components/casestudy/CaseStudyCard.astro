---
//COMPONENTS//
import { Icon } from "astro-icon/components";
import ThemeImage from "@/components/ui/ThemeImage.astro";

interface Props {
  id: string | number;
  title: string;
  image: string;
  href: string;
}

const { id, title, image, href } = Astro.props as Props;
---

<a href={href} class="group case-study-card" data-case-study-item={title}>
  <div class="flex flex-col gap-3.5 hover:cursor-pointer">
    {/* Image Container */}
    <div class="relative w-full">
      <div class="h-[250px] overflow-hidden rounded-4xl">
        <ThemeImage
          light={image}
          dark={image}
          width={100}
          height={100}
          alt={title}
          class="h-full w-full object-cover"
        />
      </div>

      {/* Icon */}
      <div
        class="lg:text-n-50 lg:group-hover:text-n-950 lg:bg-n-950 hidden transition delay-150 duration-300 ease-in-out lg:absolute lg:right-8 lg:bottom-8 lg:flex lg:items-center lg:justify-center lg:rounded-full lg:p-4 lg:group-hover:bg-blue-500"
      >
        <Icon name="external-link-icon" class="lg:h-6 lg:w-6" aria-label="View case study" />
      </div>
    </div>

    <div>
      {/* Text */}
      <p
        class="text-xl leading-tight font-medium tracking-normal group-hover:text-blue-400 md:text-2xl lg:text-3xl"
      >
        {title}
      </p>
    </div>
  </div>
</a>
