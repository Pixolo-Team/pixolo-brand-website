---
import { Icon } from "astro-icon/components";

interface Props {
  poster: string;
  name: string;
  role: string;
}

const { poster, name, role } = Astro.props as Props;
---

<div class="flex w-full flex-col gap-4 md:flex-row md:gap-7 xl:flex-col xl:gap-5">
  <!-- Media / Video wrapper -->
  <div
    class="relative aspect-[4/5] w-full overflow-hidden rounded-3xl md:aspect-[16/9] xl:aspect-[2/1]"
  >
    <!-- Poster image preview -->
    <img src={poster} alt={`Portrait of ${name}`} class="h-full w-full object-cover" />

    <!-- Play button: mobile left-aligned, md: centered, larger border -->
    <button
      type="button"
      aria-label="Play video"
      class="border-n-950 xl:bg-n-200 absolute right-3 bottom-3 flex size-10 items-center justify-start rounded-full border pl-3 md:right-5 md:bottom-5 md:size-14 md:justify-center md:border-2 md:pl-0 xl:border-0"
    >
      <Icon name="play" class="text-n-950 xl:text-n-50 size-3 md:size-4" />
    </button>
  </div>

  <!-- Name & role -->
  <div class="flex flex-col gap-0.5 md:justify-center xl:px-5">
    <p class="text-n-950 text-2xl leading-[125%] font-medium md:text-3xl xl:text-3xl">
      {name}
    </p>
    <p class="text-n-700 text-base leading-[125%] font-normal md:text-xl xl:text-xl">
      {role}
    </p>
  </div>
</div>
