---
import { Icon } from "astro-icon/components";

interface Props {
  poster: string;
  name: string;
  role: string;
  className?: string;
}

const { poster, name, role, className = "" } = Astro.props as Props;
---

<div class={`flex w-full flex-col gap-4 md:gap-7 xl:flex-col xl:gap-5 ${className}`}>
  <div class="flex w-full flex-col gap-4 md:gap-7 xl:flex-col xl:gap-5">
    <!-- Media / Video wrapper -->
    <div class="relative h-[279px] w-full overflow-hidden rounded-3xl md:h-[520px] xl:h-[520px]">
      <!-- Poster image preview -->
      <img src={poster} alt={`Portrait of ${name}`} class="h-full w-full object-cover" />

      <!-- Play button -->
      <button
        type="button"
        aria-label="Play video"
        class="border-n-950 xl:bg-n-800 absolute right-3 bottom-3 flex size-10 items-center justify-center rounded-full border md:right-5 md:bottom-5 md:size-14 md:border-2 xl:border-0"
      >
        <Icon name="play" class="text-n-950 size-[12.26px] md:size-[17.16px]" />
      </button>
    </div>

    <!-- Name & role -->
    <div class="flex flex-col gap-0.5 md:justify-center xl:px-5">
      <p class="text-n-950 text-2xl leading-[125%] font-medium md:text-3xl">
        {name}
      </p>
      <p class="text-n-700 text-base leading-[125%] font-normal md:text-xl">
        {role}
      </p>
    </div>
  </div>
</div>
