---
// COMPONENTS //
import ToolBadge from "@/components/ui/ToolBadge.astro";

interface Props {
  sectionTitle: string;
  badgeIcon: string;
  badgeText: string;
}

const { sectionTitle, badgeIcon, badgeText } = Astro.props;
---

<!-- Toolbadge & Page Title -->
<div class="flex flex-col items-center gap-4 md:gap-5">
  <!-- Toolbadge -->
  <ToolBadge icon={badgeIcon} text={badgeText} />
  <!-- Page Title -->
  <h1 class="text-n-950 text-center text-3xl leading-tight font-medium md:text-5xl lg:text-6xl">
    {sectionTitle}
  </h1>
</div>
