---
// COMPONENTS //
import { Icon } from "astro-icon/components";

export interface Props {
  label?: string;
  name: string;
  id: string;
  placeholder?: string;
  required?: boolean;
  errorMessages?: string[];
  isError?: boolean;
  isDisabled?: boolean;
}

const {
  label = "",
  placeholder = "",
  name = "",
  id = "",
  required = false,
  errorMessages = [],
  isError = false,
  isDisabled = false,
} = Astro.props;
---

<div class="flex w-full flex-col gap-3">
  <div
    class="border-n-300 focus-within:border-n-900 flex items-center gap-3 border-b pb-3 md:gap-4 md:pb-4"
  >
    <label for={id} class="shrink-0 text-sm font-medium md:text-base lg:text-lg">
      {label}
    </label>

    <div class="relative min-w-0 flex-1">
      {/* 1. The Actual Hidden Input */}
      <input
        disabled={isDisabled}
        type="file"
        id={id}
        name={name}
        required={required}
        class="peer absolute inset-0 z-10 cursor-pointer opacity-0 disabled:cursor-not-allowed"
      />

      {/* 2. The Visual "Fake" Input */}
      <div
        id={`${id}-display`}
        class="text-n-600 peer-focus:text-n-950 truncate text-sm lg:text-base"
      >
        {placeholder}
      </div>
    </div>
  </div>

  {/* Error messages section */}
  <div class="error-messages-container flex flex-col gap-2.5 md:gap-3">
    {
      isError &&
        errorMessages.map((errorMessageItem) => (
          <div class="flex items-center gap-1.5 md:gap-2">
            <Icon name="error-icon" class="size-4" />
            <p class="text-xs font-normal text-red-600 md:text-sm lg:text-base">
              {errorMessageItem}
            </p>
          </div>
        ))
    }
  </div>
</div>

<script is:inline define:vars={{ id, placeholder }}>
  // 3. The Logic to update the name
  const fileInput = document.getElementById(id);
  const displayDiv = document.getElementById(`${id}-display`);

  if (fileInput && displayDiv) {
    fileInput.addEventListener("change", (e) => {
      const files = e.target.files;
      if (files && files.length > 0) {
        // Change text to filename and make it look "active"
        displayDiv.innerText = files[0].name;
        displayDiv.classList.remove("text-n-600");
        displayDiv.classList.add("text-n-950", "font-medium");
      } else {
        // Reset if selection cleared
        displayDiv.innerText = placeholder;
        displayDiv.classList.add("text-n-600");
        displayDiv.classList.remove("text-n-950", "font-medium");
      }
    });
  }
</script>
