---
interface Props {
  title?: string;
  message?: string;
  icon?: string;
}

const {
  title = "Unable to load data",
  message = "We encountered an issue fetching the latest content. Please try again later.",
  icon = "⚠️",
} = Astro.props;
---

<div
  class="border-n-200 bg-n-100 my-12 flex flex-col items-center justify-center rounded-3xl border-2 border-dashed px-4 py-20 text-center"
>
  <div class="mb-6 text-6xl opacity-80">
    {icon}
  </div>

  <h3 class="text-n-900 mb-3 text-2xl font-bold">
    {title}
  </h3>

  <p class="text-n-600 mb-8 max-w-md leading-relaxed">
    {message}
  </p>

  <a
    href="/"
    class="text-n-50 rounded-full bg-blue-600 px-6 py-3 font-semibold shadow-lg transition-colors hover:bg-blue-700 hover:shadow-xl"
  >
    Return Home
  </a>
</div>
