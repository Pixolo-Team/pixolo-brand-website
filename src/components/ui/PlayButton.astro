---
// COMPONENTS //
import { Icon } from "astro-icon/components";

interface Props {
  id?: string;
}

const { id } = Astro.props;
---

<!-- Play Button -->
<button
  id={id}
  type="button"
  aria-label="Play video"
  class="play-button text-n-950 hover:bg-n-50 flex size-6 cursor-pointer items-center justify-center rounded-full outline -outline-offset-1 transition-all duration-300 hover:outline-0 md:size-12 lg:size-14"
>
  <!-- Play Icon -->
  <Icon name="play-icon" class="size-2 md:size-3.5" />
</button>
<style>
  .play-button {
    will-change: transform, opacity;
  }
</style>
