---
interface props {
  title: string;
  description: string;
}

const { title, description } = Astro.props as props;
---

<!-- Step Item  -->
<div
  class="step-item relative flex w-full flex-row-reverse items-center justify-center gap-12 pl-9 md:flex-row md:gap-10 md:pl-0 lg:gap-16"
>
  <!-- Title -->
  <p
    class="step-title text-n-800 flex-1 text-left text-xl leading-tight font-medium md:text-right md:text-3xl lg:text-5xl"
  >
    {title}
  </p>

  <!-- Ellipse -->
  <div class="bg-n-700 size-4 rounded-full lg:size-5"></div>

  <!-- Description -->
  <p
    class="step-description text-n-800 hidden flex-1 text-base leading-tight md:flex md:text-lg lg:text-2xl"
  >
    {description}
  </p>
</div>
<style>
  .step-item p {
    transform: translateX(40px);
    opacity: 0;
    will-change: transform, opacity;
  }
</style>
