---
// DATA //
import type { MediaBlockData } from "@/data/blogs";

interface Props {
  block: MediaBlockData;
}

const { block } = Astro.props as Props;
---

<div class="space-y-2">
  <!-- Image -->
  {
    block.mediaType === "image" && block.src && block.alt && (
      <img src={block.src} alt={block.alt} class="w-full rounded-2xl" />
    )
  }

  <!-- Video -->
  {
    block.mediaType === "video" && (
      <iframe
        class="aspect-video w-full rounded-2xl"
        src={`https://www.youtube.com/embed/${block.videoId}`}
      />
    )
  }

  <!-- Caption -->
  {block.caption && <p class="text-center text-sm opacity-70">{block.caption}</p>}
</div>
