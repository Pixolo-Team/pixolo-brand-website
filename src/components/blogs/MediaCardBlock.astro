---
import type { MediaBlock } from "@/data/blogs";

interface Props {
  block: MediaBlock;
}

const { block } = Astro.props as Props;
---

<figure class="space-y-2">
  {
    block.mediaType === "image" && (
      <img src={block.src} alt={block.alt} class="w-full rounded-2xl" />
    )
  }

  {
    block.mediaType === "video" && (
      <iframe
        class="aspect-video w-full rounded-2xl"
        src={`https://www.youtube.com/embed/${block.videoId}`}
        frameborder="0"
        allowfullscreen
      />
    )
  }

  {block.caption && <figcaption class="text-center text-sm opacity-70">{block.caption}</figcaption>}
</figure>
