---
// COMPONENTS //
import { Image } from "astro:assets";

// OTHERS //
import ToolBadge from "../ui/ToolBadge.astro";

// DATA //
import type { BlogPost } from "@/data/blogs";

interface Props {
  post: BlogPost;
}

const { post } = Astro.props as Props;
---

<section>
  <div
    class="container mx-auto flex flex-col items-center gap-7 px-6 py-24 md:gap-9 md:py-24 lg:py-28"
  >
    <!-- Badge -->
    <ToolBadge icon="package" text={post.category.label} />

    <!-- Content Section -->
    <div class="flex flex-col items-center gap-7 md:gap-14 lg:gap-16">
      <div
        class="anim-fade-in-right flex flex-col items-center justify-center gap-3 md:gap-5 lg:gap-6"
      >
        <!-- Category and Date -->
        <div class="flex items-center justify-center gap-3.5 md:gap-5">
          <div
            class="text-n-950 text-xs leading-normal font-normal capitalize md:text-lg lg:text-xl"
          >
            {post.category.type}
          </div>
          <div class="bg-n-950 h-3.5 w-px md:h-6 lg:h-11"></div>
          <div
            class="text-n-700 justify-start text-xs leading-normal capitalize md:text-lg lg:text-xl"
          >
            {post.publishedAt}
          </div>
        </div>

        <!-- Title -->
        <div
          class="text-n-950 text-center text-sm leading-tight capitalize md:text-3xl lg:px-44 lg:text-4xl"
        >
          {post.title}
        </div>

        <!-- Author -->
        <div class="text-n-700 text-center text-xs leading-normal capitalize md:text-lg lg:text-xl">
          By: {post.author.name}
        </div>
      </div>

      <!-- Hero Image -->
      <Image
        src={post.hero.image}
        alt={post.hero.alt}
        class="anim-fade-in-up container h-[295px] overflow-hidden rounded-3xl object-cover md:h-[650px] md:rounded-4xl lg:h-[650px]"
        width={1536}
        height={650}
      />
    </div>
  </div>
</section>
