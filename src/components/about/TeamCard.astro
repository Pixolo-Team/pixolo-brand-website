---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";

interface TeamMemberData {
  name: string;
  role: string;
  quote: string;
  quoteHighlight: string;
  profileImage: string;
  avatarImage: string;
  linkedinUrl: string;
  instagramUrl: string;
}

const { name, role, quote, quoteHighlight, profileImage, avatarImage, linkedinUrl, instagramUrl } =
  Astro.props as TeamMemberData;
---

<div class="flex w-full flex-col items-start gap-4 md:gap-4">
  <!-- Card Image Area -->
  <div class="relative flex w-full flex-col items-center justify-end overflow-hidden rounded-3xl">
    <!-- Background Image with Overlay -->
    <div class="w-full overflow-hidden rounded-3xl">
      <img src={profileImage} alt={name} class="h-full w-full object-contain" />
      <!-- Gradient Overlay -->
      <div
        class="absolute inset-0"
        style="
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0) 46.06%,
      rgba(0, 1, 3, 0.10) 56.25%,
      rgba(1, 3, 9, 0.28) 65.87%,
      #040B20 100%
    );
  "
      >
      </div>
    </div>

    <!-- Content -->
    <div class="absolute bottom-0 z-10 inline-flex w-full items-end gap-3 px-5 py-6">
      <!-- Quote -->
      <div class="relative flex flex-1 items-center gap-3 pl-7 md:pl-7 lg:pl-9">
        <p class="text-sm leading-4 text-white md:leading-4 lg:text-base lg:leading-5">
          <span class="font-normal">{quote}</span>
          <span class="font-extrabold">{quoteHighlight}</span>
        </p>

        <!-- Inverted Commas -->
        <Icon name="quote-icon" class="absolute -top-2 left-0 size-5 lg:size-7" />
      </div>

      <!-- Avatar -->
      <img src={avatarImage} alt={name} class="size-12 rounded-full object-cover lg:size-16" />
    </div>
  </div>

  <!-- Info -->
  <div class="flex w-full flex-col gap-3">
    <div class="flex items-center justify-between gap-3">
      <!-- Name -->
      <div class="flex w-full flex-col gap-0.5">
        <span class="text-n-950 text-xs font-normal md:text-xs lg:text-sm">This is</span>
        <span class="text-n-950 text-xl font-extrabold md:text-2xl lg:text-3xl">
          {name}
        </span>
      </div>

      <!-- Social Icons -->
      <div class="flex items-center gap-1.5">
        <a
          href={linkedinUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-n-950 flex items-center justify-center rounded-4xl p-3 transition-opacity hover:opacity-80 md:p-3 lg:p-3.5"
          aria-label="LinkedIn Profile"
        >
          <Icon name="linkedin" class="text-n-100 size-4 md:size-4 lg:size-5" />
        </a>

        <a
          href={instagramUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-n-950 flex items-center justify-center rounded-4xl p-3 transition-opacity hover:opacity-80 md:p-3 lg:p-3.5"
          aria-label="Instagram Profile"
        >
          <Icon name="instagram" class="text-n-100 size-4 md:size-4 lg:size-5" />
        </a>
      </div>
    </div>

    <!-- Role Badge -->
    <div
      class="flex w-fit items-center rounded-2xl bg-gradient-to-r from-indigo-600 to-indigo-400 px-5 py-1.5 outline -outline-offset-1 outline-indigo-600"
    >
      <span class="text-n-950 text-xs leading-4 font-bold lg:text-sm">
        {role}
      </span>
    </div>
  </div>
</div>
