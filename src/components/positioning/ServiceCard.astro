---
// COMPONENTS //
import { Icon } from "astro-icon/components";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props as Props;
---

<!-- Service Card Component -->
<div
  class="service-card bg-n-100 outline-n-300 flex w-full flex-col items-start gap-7 rounded-[32px] px-5 py-6 outline -outline-offset-1 md:gap-9 md:px-6 md:py-7 lg:gap-11 lg:px-7 lg:py-8"
>
  <!-- Logo Icon -->
  <Icon name={"logo-icon"} class="size-12 md:size-14 lg:size-16" />

  <!-- Content -->
  <div class="flex w-full flex-col gap-1.5 md:gap-2 lg:gap-2.5">
    <!-- Title -->
    <p class="text-n-950 text-xl leading-tight font-medium md:text-2xl lg:text-3xl">
      {title}
    </p>

    <!-- Description -->
    <p class="text-n-700 text-base leading-tight font-normal md:text-lg lg:text-xl">
      {description}
    </p>
  </div>
</div>
