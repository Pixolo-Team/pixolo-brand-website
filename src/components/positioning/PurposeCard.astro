---
// COMPONENTS //
import { Icon } from "astro-icon/components";

interface Props {
  index: string;
  title: string;
  description: string;
}

const { index, title, description } = Astro.props as Props;
---

<!-- Purpose Card Component -->
<div
  class="purpose-card outline-n-300 flex w-full flex-col gap-6 rounded-[32px] p-5 outline-2 -outline-offset-2 md:gap-12 md:px-7 md:py-8 lg:gap-14 lg:px-8 lg:py-10"
>
  <!-- Top Row -->
  <div class="flex items-start justify-between">
    <!-- Index -->
    <p class="text-n-400 text-2xl leading-tight font-semibold md:text-4xl lg:text-5xl">
      {index}
    </p>

    <!-- Icon -->
    <Icon name="logo-icon" class="size-10 md:size-14 lg:size-16" />
  </div>

  <!-- Content -->
  <div class="flex flex-col gap-4">
    <!-- Title -->
    <p
      class="text-n-950 w-[80%] text-xl leading-tight font-medium md:text-3xl lg:w-[80%] lg:text-4xl xl:w-[70%] 2xl:w-[60%]"
    >
      {title}
    </p>

    <!-- Description -->
    <p class="text-n-700 text-sm leading-tight font-normal md:text-lg lg:text-xl">
      {description}
    </p>
  </div>
</div>
