---
// COMPONENTS //
import { Icon } from "astro-icon/components";

interface Props {
  title: string;
  icon: string;
  description?: string;
}

const { title, icon, description = "" } = Astro.props as Props;
---

<div
  class="result-card bg-n-100 outline-n-300 flex w-full flex-col items-center justify-center gap-3 rounded-3xl px-6 py-7 outline -outline-offset-1 md:gap-4"
>
  <!-- Icon Wrapper -->
  <div
    class="flex items-center justify-center rounded-3xl bg-linear-to-r from-indigo-600 to-indigo-400 p-3.5 md:p-4 lg:p-4.5"
  >
    <!-- Icon -->
    <Icon name={icon} class="size-6 text-white md:size-7 lg:size-8" />
  </div>

  <div class="flex flex-col items-center justify-center gap-1">
    <!-- Title -->
    <p
      class="text-n-800 w-[65%] text-center text-lg leading-tight font-bold md:w-[90%] md:text-xl lg:text-2xl xl:w-[85%]"
    >
      {title}
    </p>

    {
      description !== "" && (
        // Description
        <p class="text-n-800 w-[65%] text-center text-xs leading-tight font-normal md:w-[90%] md:text-sm xl:w-[85%]">
          {description}
        </p>
      )
    }
  </div>
</div>
