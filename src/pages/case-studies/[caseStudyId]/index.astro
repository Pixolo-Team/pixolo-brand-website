---
export function getStaticPaths() {
  const paths = [];
  for (let i = 1; i <= 12; i++) {
    paths.push({
      params: { caseStudyId: i.toString() },
    });
  }
  return paths;
}

// OTHERS //
import Layout from "@/layouts/Layout.astro";

// SECTIONS //
import Numbers from "@/sections/case-studies/Numbers.astro";
import ClientVision from "@/sections/case-studies/ClientVision.astro";
import Solutions from "@/sections/case-studies/Solutions.astro";
import Issues from "@/sections/case-studies/Issues.astro";
import AboutTheClient from "@/sections/case-studies/AboutTheClient.astro";
import SolutionNumbers from "@/sections/case-studies/SolutionNumbers.astro";

const { caseStudyId } = Astro.params;
const allData = await import(`@/data/case-studies/cs-${caseStudyId}.json`);
const data = allData.default;
const getSection = (id: string) => data.sections.find((s: any) => s.id === id);
---

<Layout>
  <Numbers data={getSection("by_the_numbers")} />
  <ClientVision data={getSection("client_vision")} />
  <Issues data={getSection("client_issues")} />
  <AboutTheClient data={getSection("about_client")} />
  <Solutions data={getSection("solutions")} />
  <SolutionNumbers data={getSection("numbers_after_the_solution")} />
</Layout>
