---
// OTHERS //
import Layout from "@/layouts/Layout.astro";

// SECTIONS //
import Numbers from "@/sections/case-studies/Numbers.astro";
import ClientVision from "@/sections/case-studies/ClientVision.astro";
import Solutions from "@/sections/case-studies/Solutions.astro";
import Issues from "@/sections/case-studies/Issues.astro";
import AboutTheClient from "@/sections/case-studies/AboutTheClient.astro";
import Gallery from "@/sections/case-studies/Gallery.astro";
import ToolsUsed from "@/sections/case-studies/ToolsUsed.astro";
import ClientTestimonial from "@/sections/case-studies/ClientTestimonial.astro";
import SolutionNumbers from "@/sections/case-studies/SolutionNumbers.astro";
import Hero from "@/sections/case-studies/Hero.astro";
import KeyTakeaways from "@/sections/case-studies/KeyTakeaways.astro";
import { caseStudies } from "@/data/case-studies/case-studies";

/**
 * Generate static paths for all service pages
 * @returns Array of static paths with service data
 */
export function getStaticPaths() {
  const paths: Array<{
    params: { id: string; pageTitle: string };
    props: { caseStudy: any };
  }> = [];

  caseStudies.forEach((caseStudy) => {
    paths.push({
      params: {
        id: caseStudy.id.toString(),
        pageTitle: caseStudy.pageTitle.replaceAll(" ", "-").toLowerCase(),
      },
      props: {
        caseStudy,
      },
    });
  });

  return paths;
}

const { caseStudy } = Astro.props;
---

<Layout>
  <Hero data={caseStudy.sections.find((s: any) => s.id === "hero")} />
  <Numbers data={caseStudy.sections.find((s: any) => s.id === "by_the_numbers")} />
  <AboutTheClient data={caseStudy.sections.find((s: any) => s.id === "about_client")} />
  <Issues data={caseStudy.sections.find((s: any) => s.id === "client_issues")} />
  <ClientVision data={caseStudy.sections.find((s: any) => s.id === "client_vision")} />
  <Solutions data={caseStudy.sections.find((s: any) => s.id === "solutions")} />
  <Gallery data={caseStudy.sections.find((s: any) => s.id === "gallery")} />
  <KeyTakeaways data={caseStudy.sections.find((s: any) => s.id === "key_takeaways")} />
  <!-- <ToolsUsed />
  <ClientTestimonial /> -->
  <SolutionNumbers
    data={caseStudy.sections.find((s: any) => s.id === "numbers_after_the_solution")}
  />
</Layout>
