---
// Components //
import ProjectShowcaseCard from "@/components/portfolio-showcase/ProjectShowcaseCard.astro";
import ArticleCard from "@/components/ArticleCard.astro";
import ProjectCard from "@/components/portfolio/ProjectCard.astro";
---

<div class="container mx-auto flex flex-col items-center justify-center gap-4">
  <ProjectShowcaseCard
    name={"default-project"}
    image={"/images/default-showcase-project-image.jpg"}
    title={"Sai International School"}
    subtitle={"A Fintech Project"}
    description={"Sai International School is known for its strong academic foundation, modern learning environment, and a holistic approach that blends education, values, and real-world skills."}
    date={"July 2024"}
    badgeItems={["Website", "Mobile App", "Laptop"]}
    buttonOneText={"View Website"}
    buttonTwoText={"Show Project"}
    view={"grid"}
  />

  <ArticleCard
    thumbnail="/images/portfolio/default-project.jpg"
    brandName="reliance"
    chipItems={["Product Design", "App Development", "Dashboard Design"]}
    title="E-commerce Platform for Local Brands"
    subtitle="Built a scalable e-commerce solution empowering small businesses to sell online with zero code setup."
    ctaText="View Case Study"
  />

  <ProjectCard
    brandColor="bg-red-500"
    brandName="Reliance"
    image="images/portfolio/reliance-brand-image.png"
    logo="images/portfolio/reliance-logo.png"
    title="E-commerce Platform for Local Brands"
    subtitle="Built a scalable e-commerce solution empowering small businesses to sell online with zero code setup."
    badges={["Product Design", "App Development", "Dashboard Design"]}
  />
</div>
