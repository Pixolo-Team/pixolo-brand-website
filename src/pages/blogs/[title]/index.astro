---
/** Get Static Paths */
export function getStaticPaths() {
  return [
    { params: { title: "blog-1" } },
    { params: { title: "blog-2" } },
    { params: { title: "blog-3" } },
  ];
}

const { title } = Astro.params;

// COMPONENTS //
import BlogHero from "@/components/blogs-consumption/BlogHero.astro";

// OTHERS //
import Layout from "@/layouts/Layout.astro";

// DATA //
import { blogConsumptionDetails } from "@/data/blog-consumption";
---

<Layout>
  <BlogHero post={blogConsumptionDetails} />
</Layout>
