---
// TYPES //
import type { BlogPost } from "@/types/blogs";

// COMPONENTS //
import BlogHero from "@/components/blogs-consumption/BlogHero.astro";
import BlogBody from "@/components/blogs-consumption/BlogBody.astro";

// API SERVICES //
import { getBlogsRequest } from "@/services/api/blogs.api";

// OTHERS //
import Layout from "@/layouts/Layout.astro";

/** Generates static paths for all blogs */
export async function getStaticPaths() {
  /** API Call to get Blogs */
  const blogs = await getBlogsRequest();

  return blogs.map((blogItem: BlogPost) => ({
    params: {
      pageTitle: blogItem.title.replaceAll(" ", "-").toLowerCase(),
    },
    props: {
      blogItem,
    },
  }));
}

const { blogItem }: { blogItem: BlogPost } = Astro.props;
---

<Layout>
  <BlogHero post={blogItem} />
  <BlogBody content={blogItem} />
</Layout>
