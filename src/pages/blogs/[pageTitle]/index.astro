---
/** Get Static Paths */
export function getStaticPaths() {
  return [
    { params: { pageTitle: "blog-1" } },
    { params: { pageTitle: "blog-2" } },
    { params: { pageTitle: "blog-3" } },
  ];
}

const { pageTitle } = Astro.params;

// COMPONENTS //
import BlogHero from "@/components/blogs-consumption/BlogHero.astro";
import BlogBody from "@/components/blogs-consumption/BlogBody.astro";

// OTHERS //
import Layout from "@/layouts/Layout.astro";

// DATA //
import { blogConsumptionDetails } from "@/data/blog-consumption.ts";
---

<Layout>
  <BlogHero post={blogConsumptionDetails} />
  <BlogBody content={blogConsumptionDetails.content} />
</Layout>
