import servicesMeta from "@/data/meta/services/services.json";
import { pixoloServicesItemListSchema } from "@/schemas/services/services";

// OTHERS //
import Layout from "@/layouts/Layout.astro";
---

<Layout meta={servicesMeta}>
  <!-- Services ItemList JSON-LD -->
  <JsonLd slot="head" data={pixoloServicesItemListSchema} />

  <Hero />
  <Service />
</Layout>
