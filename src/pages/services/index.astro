---
// COMPONENTS //
import JsonLd from "@/components/layout/JsonLd.astro";

// UTILS //
import { getSiteUrl } from "@/utils/site-url";

// SERVICES //
import Hero from "@/sections/services/Hero.astro";
import Service from "@/sections/services/Service.astro";
import { pixoloServicesItemListSchema } from "@/schemas/services/services.schema";

// DATA //
import servicesMeta from "@/data/meta/services/services.json";

// OTHERS //
import Layout from "@/layouts/Layout.astro";
import { pixoloIndustriesServedSchema } from "@/schemas/industries-served";
---

<Layout meta={{ ...servicesMeta, image: `${getSiteUrl()}/images/og/service.jpg` }}>
  {/* Services ItemList JSON-LD */}
  <JsonLd slot="head" data={pixoloServicesItemListSchema} />
  {/* Industries Served JSON-LD */}
  <JsonLd slot="head" data={pixoloIndustriesServedSchema} />

  <Hero />
  <Service />
</Layout>
