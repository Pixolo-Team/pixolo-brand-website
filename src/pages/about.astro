---
// COMPONENTS //
import JsonLd from "@/components/layout/JsonLd.astro";

// OTHERS //
import Layout from "@/layouts/Layout.astro";
import { pixoloIndustriesServedSchema } from "@/schemas/industries-served";
import { pixoloPlaceSchema } from "@/schemas/place.schema";

// SECTIONS //
import Team from "@/sections/about/Team.astro";
import Leadership from "@/sections/about/Leadership.astro";
import Prevention from "@/sections/about/Prevention.astro";
import Pov from "@/sections/about/Pov.astro";
import Process from "@/sections/about/Process.astro";
import Hero from "@/sections/about/Hero.astro";
import Commitment from "@/sections/about/Commitment.astro";

// DATA //
import aboutMeta from "@/data/meta/about.json";
---

<Layout meta={aboutMeta}>
  {/* Industries Served JSON-LD */}
  <JsonLd slot="head" data={pixoloIndustriesServedSchema} />
  {/* Place Schema JsonLd */}
  <JsonLd slot="head" data={pixoloPlaceSchema} />

  <Hero />
  <Team />
  <Pov />
  <Prevention />
  <Process />
  <Leadership />
  <Commitment />
</Layout>
