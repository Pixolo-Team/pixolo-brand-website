---
// COMPONENTS //
import JsonLd from "@/components/layout/JsonLd.astro";

// OTHERS //
import Layout from "@/layouts/Layout.astro";
import { pixoloIndustriesServedSchema } from "@/schemas/industries-served";
import { pixoloPlaceSchema } from "@/schemas/place.schema";

// SECTIONS //
import Leadership from "@/sections/about/Leadership.astro";

// DATA //
import aboutMeta from "@/data/meta/about.json";
---

<Layout meta={aboutMeta}>
  {/* Industries Served JSON-LD */}
  <JsonLd slot="head" data={pixoloIndustriesServedSchema} />
  {/* Place Schema JsonLd */}
  <JsonLd slot="head" data={pixoloPlaceSchema} />

  <Leadership />
</Layout>
