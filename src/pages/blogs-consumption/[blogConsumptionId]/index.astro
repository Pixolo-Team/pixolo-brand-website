---
export function getStaticPaths() {
  return [
    { params: { blogConsumptionId: "1" } },
    { params: { blogConsumptionId: "2" } },
    { params: { blogConsumptionId: "3" } },
  ];
}

const { blogConsumptionId } = Astro.params;

// COMPONENTS //
import BlogHero from "@/components/blogs/BlogHero.astro";
import BlogBody from "@/components/blogs/BlogBody.astro";

// OTHERS //
import Layout from "@/layouts/Layout.astro";

// DATA //
import blogData from "@/data/blogs/1.ts";
---

<Layout>
  <BlogHero post={blogData} />
  <BlogBody content={blogData.content} />
</Layout>
