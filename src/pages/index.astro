---
// COMPONENTS //
import JsonLd from "@/components/layout/JsonLd.astro";
import ContactForm from "@/components/forms/ContactForm.astro";

// UTILS //
import { getSiteUrl } from "@/utils/site-url";

// OTHERS //
import Layout from "@/layouts/Layout.astro";
import { pixoloOrganizationSchema } from "@/schemas/home/organization.schema";

// SECTIONS //
import Hero from "@/sections/home/Hero.astro";
import Clients from "@/sections/home/Clients.astro";
import Portfolio from "@/sections/home/Portfolio.astro";
import Industries from "@/sections/home/Industries.astro";
import Retainership from "@/sections/home/Retainership.astro";
import Products from "@/sections/home/Products.astro";
import Service from "@/sections/home/Service.astro";
import Contact from "@/sections/home/Contact.astro";
import Testimonials from "@/sections/home/Testimonials.astro";
import CaseStudies from "@/sections/home/CaseStudies.astro";
import Blogs from "@/sections/home/Blogs.astro";

// DATA //
import homeMeta from "@/data/meta/home.json";
---

<Layout meta={{ ...homeMeta, image: `${getSiteUrl()}/images/og/home.jpg` }}>
  {/* Organization JSON-LD */}
  <JsonLd slot="head" data={pixoloOrganizationSchema} />

  <Hero />
  <Clients />
  <Service />
  <Retainership />
  <Portfolio />
  <CaseStudies />
  <Products />
  <Testimonials />
  <Industries />
  <Blogs />
  <Contact />
  <ContactForm />
</Layout>
