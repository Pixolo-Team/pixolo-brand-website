---
import Layout from "@/layouts/Layout.astro";
import ToolBadge from "@/components/ToolBadge.astro";
---

<style>
  @keyframes float {
    0% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-15px);
    }
    100% {
      transform: translateY(0);
    }
  }

  .floating {
    animation: float 4s ease-in-out infinite;
  }
</style>

<Layout>
  <section>
    <div
      class="relative container mx-auto flex min-h-screen max-w-[1440px] flex-col items-center gap-14 px-5 px-6 pt-20 pb-14 text-center md:gap-20 md:px-12 md:pt-36 lg:px-0 lg:pt-64"
    >
      <!-- 404 Vibes Badge -->
      <div
        class="absolute top-3.5 left-0 rotate-[-14deg] md:top-20 md:right-auto md:left-10 lg:top-45 lg:left-70"
      >
        <ToolBadge icon="alert" text="404 vibes only" />
      </div>

      <!-- Astronaut Left -->
      <img
        src="/images/astronaut.png"
        alt="astronaut"
        class="absolute top-[220px] left-0 w-10 md:top-1/2 md:left-10 md:w-24 md:-translate-y-1/2"
      />

      <!-- Astronaut Right -->
      <img
        src="/images/astronaut.png"
        alt="astronaut"
        class="absolute top-[340px] right-5 w-6 md:top-[65%] md:right-10 md:w-9"
      />

      <!-- 404 Image -->
      <img
        src="/images/404.png"
        alt="404"
        class="floating mx-auto w-[269px] md:w-[576px] lg:w-[775px]"
      />

      <!-- Text -->
      <div class="flex flex-col gap-7 md:gap-8">
        <h2
          class="text-n-950 mx-auto text-2xl leading-tight font-bold md:text-3xl lg:max-w-[620px] lg:text-4xl"
        >
          “Captain, something weird just happened… again.”
        </h2>

        <p
          class="text-n-700 mx-auto text-sm leading-tight font-normal md:max-w-[720px] md:text-2xl lg:max-w-[860px] lg:text-balance"
        >
          Oops! You've ventured into the digital void. The page you are looking for has apparently
          escaped into another dimension.
        </p>
      </div>

      <!-- CTA -->
      <div class="mt-10">
        <a
          href="/"
          class="group inline-flex items-center justify-center rounded-full bg-blue-600 px-6 py-3 font-bold text-white transition-all hover:-translate-y-1 hover:bg-blue-700 hover:shadow-2xl active:scale-95"
        >
          <span class="mr-2 text-xl group-hover:animate-bounce">🚀</span>
          Abort Mission & Teleport Home
        </a>
      </div>
    </div>
  </section>
</Layout>
