---
import Layout from "@/layouts/Layout.astro";
import ToolBadge from "@/components/ToolBadge.astro";
---

<style>
  /* Floating animation for astronauts */
  @keyframes float {
    0% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-15px);
    }
    100% {
      transform: translateY(0px);
    }
  }

  .floating {
    animation: float 4s ease-in-out infinite;
  }

  /* Slow rotation effect */
  @keyframes rotate-slow {
    0% {
      transform: rotate(0deg);
    }
    100% {
      transform: rotate(360deg);
    }
  }

  .rotating {
    animation: rotate-slow 20s linear infinite;
  }
</style>

<Layout>
  <main
    class="relative container m-auto flex min-h-screen flex-col items-center justify-center overflow-hidden px-6 text-center"
  >
    <!-- 404 Vibes Badge -->
    <div class="absolute top-55 left-90 rotate-[-13.99deg]">
      <ToolBadge icon="alert" text="404 vibes only" />
    </div>
    <!-- LEFT Astronaut -->
    <div class="relative gap-20">
      <img
        src="/images/astronaut.png"
        alt="astronaut"
        class="floating absolute top-1/2 -left-50 h-[143.1px] -translate-y-1/2 rotate-[39.27deg]"
      />

      <!-- RIGHT Astronaut -->
      <img
        src="/images/astronaut.png"
        alt="astronaut"
        class="floating absolute top-1/2 -right-50 h-[44.72px] rotate-[27.76deg]"
      />
      <!-- 404 Image -->
      <img src="/images/404.png" alt="404" class="floating m-auto w-[540px]" />

      <!-- Text Content -->
      <div class="mx-auto mt-10 max-w-2xl space-y-4 px-6 leading-tight">
        <h2 class="text-3xl font-bold text-white sm:text-4xl">
          “Captain, something weird just happened… again.”
        </h2>
        <p class="text-n-800 text-lg font-normal sm:text-xl">
          Oops! You've ventured into the digital void. The page you are looking for has apparently
          escaped into another dimension.
        </p>
      </div>

      <!-- Button -->
      <div class="mt-12">
        <a
          href="/"
          class="group relative inline-flex items-center justify-center rounded-full bg-blue-600 px-8 py-4 font-bold text-white transition-all duration-300 hover:-translate-y-1 hover:bg-blue-700 hover:shadow-2xl focus:ring-4 focus:ring-blue-300 focus:outline-none active:scale-95"
        >
          <span class="mr-2 text-2xl group-hover:animate-bounce">🚀</span>
          Abort Mission & Teleport Home
        </a>
      </div>
    </div>
  </main>
</Layout>
