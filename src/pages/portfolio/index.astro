---
// COMPONENTS //
import JsonLd from "@/components/layout/JsonLd.astro";

// OTHERS //
import Layout from "@/layouts/Layout.astro";
import { portfolioCollectionSchema } from "@/schemas/portfolio/portfolio.schema";
import { getPortfolioIndustriesSchema } from "@/schemas/portfolio/industries.schema";

// SECTIONS //
import Hero from "@/sections/portfolio/Hero.astro";
import Industries from "@/sections/portfolio/Industries.astro";
import Showcase from "@/sections/portfolio/Showcase.astro";

// DATA //
import { portfolioIndustryDetails } from "@/data/portfolio/industries.ts";
import portfolioMeta from "@/data/meta/portfolio/portfolio.json";
---

<Layout meta={portfolioMeta}>
  {/* Portfolio CollectionPage JSON-LD */}
  <JsonLd slot="head" data={portfolioCollectionSchema} />

  {/* Portfolio Industries JSON-LD */}
  <JsonLd slot="head" data={getPortfolioIndustriesSchema(portfolioIndustryDetails)} />

  <Hero />
  <Industries portfolioIndustryDetails={portfolioIndustryDetails} />
  <Showcase />
</Layout>
